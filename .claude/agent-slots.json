      "gemini-1.5-flash-8b-slot",
      "claude-slot-1",
      "codex-slot-1",
      "devin-slot-1"
    ],
    "weights": {
      "gemini-2.5-pro-slot": 0.20,
      "gemini-2.5-flash-slot": 0.20,
      "gemini-2.0-flash-slot": 0.15,
      "gemini-2.0-flash-lite-slot": 0.10,
      "gemini-1.5-pro-slot": 0.10,
      "gemini-1.5-flash-slot": 0.10,
      "gemini-1.5-flash-8b-slot": 0.05,
      "claude-slot-1": 0.05,
      "codex-slot-1": 0.03,
      "devin-slot-1": 0.02
    },
