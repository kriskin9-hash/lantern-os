      "lightweight_tasks": "gemini-2.0-flash-lite-slot",
      "micro_tasks": "gemini-1.5-flash-8b-slot",
      "deep_reasoning": "claude-slot-1",
      "deep_engineering_work": "devin-slot-1"
    }
  },
  "monitoring": {
    "enabled": true,
    "metrics": ["token_usage", "task_throughput", "error_rate", "response_time", "quota_utilization"],
    "alerts": {
      "highErrorRate": { "threshold": 0.05, "action": "failover" },
      "quotaExhaustion": { "threshold": 0.80, "action": "alert_and_route_to_fallback" },
      "slotUnhealthy": { "action": "remove_from_pool" }
    }
  },
  "security": {
    "apiKeyRotation": { "enabled": true, "interval": 86400 },
    "auditLogging": { "enabled": true, "logLevel": "detailed" },
    "tokenEncryption": { "enabled": true, "algorithm": "AES-256" }
  },
  "performance": {
    "caching": { "enabled": true, "ttl": 3600, "maxSize": "1GB" },
    "rateLimit": { "enabled": true, "requestsPerSecond": 100 },
    "timeouts": { "taskTimeout": 3600, "queueTimeout": 300, "healthCheckTimeout": 10 }
  }
