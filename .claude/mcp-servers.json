{
  "version": "1.0.0",
  "description": "MCP Server Configuration for Lantern OS v1.0.0",
  "servers": [
    {
      "id": "lantern-orchestrator",
      "name": "Lantern Orchestrator",
      "command": "python",
      "args": ["apps/orchestrator/mcp-server.py"],
      "port": 8000,
      "protocols": ["stdio", "sse"],
      "capabilities": [
        "tools/list",
        "tools/execute",
        "resources/list",
        "resources/read",
        "prompts/list",
        "prompts/get"
      ],
      "tools": [
        {
          "name": "agent_create",
          "description": "Create a new AI agent slot",
          "category": "agent_management"
        },
        {
          "name": "agent_assign_task",
          "description": "Assign a task to an agent slot",
          "category": "task_management"
        },
        {
          "name": "agent_get_status",
          "description": "Get status of an agent slot",
          "category": "monitoring"
        },
        {
          "name": "task_create",
          "description": "Create a new task in the queue",
          "category": "task_management"
        },
        {
          "name": "task_list",
          "description": "List tasks by status",
          "category": "task_management"
        },
        {
          "name": "task_update_status",
          "description": "Update task status",
          "category": "task_management"
        },
        {
          "name": "worktree_create",
          "description": "Create a git worktree for isolated development",
          "category": "git_management"
        },
        {
          "name": "worktree_cleanup",
          "description": "Clean up merged worktrees",
          "category": "git_management"
        },
        {
          "name": "batch_sync_jobs",
          "description": "Run batch sync across all agent slots",
          "category": "batch_operations"
        },
        {
          "name": "capability_check",
          "description": "Check agent capability and token quota",
          "category": "capability_management"
        },
        {
          "name": "mcp_boundary_validate",
          "description": "Validate MCP tool boundaries and permissions",
          "category": "security"
        },
        {
          "name": "health_check_all",
          "description": "Run health checks across all services",
          "category": "monitoring"
        },
        {
          "name": "logs_tail",
          "description": "Stream logs from any service",
          "category": "monitoring"
        },
        {
          "name": "metrics_get",
          "description": "Retrieve performance metrics",
          "category": "monitoring"
        }
      ],
      "resources": [
        {
          "uri": "lantern://agents",
          "name": "Agent Slots",
          "description": "Registered agent slots and status"
        },
        {
          "uri": "lantern://tasks",
          "name": "Task Queue",
          "description": "Current task queue and history"
        },
        {
          "uri": "lantern://worktrees",
          "name": "Git Worktrees",
          "description": "Active git worktrees for development"
        },
        {
          "uri": "lantern://services",
          "name": "Services",
          "description": "Running Lantern services status"
        },
        {
          "uri": "lantern://metrics",
          "name": "Metrics",
          "description": "Performance and usage metrics"
        }
      ],
      "env": {
        "ORCHESTRATOR_MODE": "production",
        "MCP_PROTOCOL": "sse",
        "LOG_LEVEL": "info"
      },
      "timeout": 30,
      "autoStart": true,
      "restartOnFailure": true,
      "restartDelay": 5
    },
    {
      "id": "lantern-api",
      "name": "Lantern API Server",
      "command": "python",
      "args": ["-m", "flask", "run", "--port=5000"],
      "port": 5000,
      "protocols": ["http"],
      "healthCheck": {
        "endpoint": "/health",
        "interval": 30,
        "timeout": 5
      },
      "env": {
        "FLASK_APP": "apps/lantern-api/app.py",
        "FLASK_ENV": "production"
      },
      "timeout": 30,
      "autoStart": true,
      "restartOnFailure": true
    },
    {
      "id": "lantern-rag",
      "name": "Lantern RAG Server",
      "command": "python",
      "args": ["apps/rag-server/server.py"],
      "port": 8767,
      "protocols": ["http"],
      "capabilities": [
        "embeddings",
        "search",
        "retrieval"
      ],
      "healthCheck": {
        "endpoint": "/health",
        "interval": 30,
        "timeout": 5
      },
      "env": {
        "RAG_MODE": "production",
        "EMBEDDING_MODEL": "sentence-transformers/all-MiniLM-L6-v2"
      },
      "timeout": 30,
      "autoStart": true,
      "restartOnFailure": true
    }
  ],
  "globalSettings": {
    "maxRetries": 3,
    "retryDelay": 2000,
    "requestTimeout": 30000,
    "poolSize": 10,
    "enableLogging": true,
    "logLevel": "info"
  },
  "security": {
    "validateSignatures": true,
    "tlsRequired": true,
    "allowedOrigins": [
      "https://lantern-os.app",
      "http://localhost:*"
    ],
    "rateLimiting": {
      "enabled": true,
      "requestsPerMinute": 1000,
      "burstSize": 100
    }
  }
}
