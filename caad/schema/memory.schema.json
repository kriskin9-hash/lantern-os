{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lantern OS CSF/CADD Memory Schema",
  "description": "MemOS-tier memory system. Raw dream/session material preserved before promotion into policies, world-model entities, and reusable skills.",
  "type": "object",
  "required": ["memory_id", "tier", "created_at", "content", "confidence", "privacy_scope"],
  "properties": {
    "memory_id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
    "tier": {
      "type": "string",
      "enum": ["trace", "correction", "anchor", "entity", "relation", "ritual", "skill", "export"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "content": { "type": "object" },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Brier-calibrated confidence. 1.0 = certain, 0.0 = wild guess."
    },
    "privacy_scope": {
      "type": "string",
      "enum": ["private", "internal", "public", "export_safe"],
      "description": "private = never leaves local machine. internal = within Lantern OS. public = shareable. export_safe = cleared for external release."
    },
    "source_surface": { "type": "string", "description": "Where this memory originated (e.g., dream-chat, convergence-loop, manual-entry)" },
    "promoted_from": { "type": "string", "description": "memory_id of the parent record this was promoted from" },
    "promotion_chain": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered list of tier transitions this record has undergone"
    },
    "cube_partition": {
      "type": "string",
      "enum": ["raw", "refined", "canon", "archive"],
      "description": "raw = unprocessed input. refined = cleaned and tagged. canon = approved world-model. archive = cold storage."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "agents": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Agents that have touched or validated this record"
    },
    "checksum": { "type": "string", "description": "SHA-256 of canonical JSON representation" },
    "vector_embedding": {
      "type": "array",
      "items": { "type": "number" },
      "description": "Optional semantic embedding for similarity search"
    }
  },
  "definitions": {
    "TraceContent": {
      "type": "object",
      "required": ["text", "session_id"],
      "properties": {
        "text": { "type": "string" },
        "session_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "surface": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant", "system", "observer"] },
        "raw_input": { "type": "string", "description": "Unmodified user input before any processing" }
      }
    },
    "CorrectionContent": {
      "type": "object",
      "required": ["original_memory_id", "corrected_field", "reason"],
      "properties": {
        "original_memory_id": { "type": "string" },
        "corrected_field": { "type": "string" },
        "old_value": {},
        "new_value": {},
        "reason": { "type": "string" },
        "corrected_by": { "type": "string" },
        "correction_type": { "type": "string", "enum": ["factual", "privacy", "style", "safety", "consistency"] }
      }
    },
    "AnchorContent": {
      "type": "object",
      "required": ["text", "anchor_type"],
      "properties": {
        "text": { "type": "string" },
        "anchor_type": { "type": "string", "enum": ["keystone", "lantern", "xenon", "door", "threshold", "personal"] },
        "attested_by": { "type": "array", "items": { "type": "string" } },
        "attestation_count": { "type": "integer", "minimum": 0 },
        "last_attested_at": { "type": "string", "format": "date-time" }
      }
    },
    "EntityContent": {
      "type": "object",
      "required": ["name", "entity_type"],
      "properties": {
        "name": { "type": "string" },
        "entity_type": { "type": "string", "enum": ["character", "place", "symbol", "concept", "artifact", "faction"] },
        "description": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "first_seen_at": { "type": "string", "format": "date-time" },
        "occurrence_count": { "type": "integer", "minimum": 0 }
      }
    },
    "RelationContent": {
      "type": "object",
      "required": ["subject_id", "relation_type", "object_id"],
      "properties": {
        "subject_id": { "type": "string" },
        "relation_type": { "type": "string", "enum": ["contains", "references", "contradicts", "supports", "transforms_into", "remembers", "guides"] },
        "object_id": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "bidirectional": { "type": "boolean", "default": false }
      }
    },
    "RitualContent": {
      "type": "object",
      "required": ["name", "steps"],
      "properties": {
        "name": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } },
        "trigger_surface": { "type": "string" },
        "invocation_count": { "type": "integer", "minimum": 0 },
        "last_invoked_at": { "type": "string", "format": "date-time" }
      }
    },
    "SkillContent": {
      "type": "object",
      "required": ["name", "capability"],
      "properties": {
        "name": { "type": "string" },
        "capability": { "type": "string" },
        "implementation_ref": { "type": "string", "description": "Path to code or spec implementing this skill" },
        "tested": { "type": "boolean", "default": false },
        "test_results": { "type": "array", "items": { "type": "object" } },
        "crystallized_at": { "type": "string", "format": "date-time" }
      }
    },
    "ExportContent": {
      "type": "object",
      "required": ["format", "destination", "payload"],
      "properties": {
        "format": { "type": "string", "enum": ["csf", "json", "markdown", "pdf", "pcsf"] },
        "destination": { "type": "string" },
        "payload": {},
        "cleared_by": { "type": "array", "items": { "type": "string" } },
        "clearance_reason": { "type": "string" }
      }
    }
  }
}
