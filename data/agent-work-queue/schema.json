{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Work Queue Entry",
  "description": "Schema for work items in the autonomous agent queue",
  "type": "object",
  "required": ["id", "issueNumber", "title", "status", "createdAt", "updatedAt"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^issue-[0-9]+$",
      "description": "Unique work item identifier (issue-{number})"
    },
    "issueNumber": {
      "type": "integer",
      "minimum": 1,
      "description": "GitHub issue number"
    },
    "title": {
      "type": "string",
      "description": "Issue title"
    },
    "description": {
      "type": "string",
      "description": "Full issue description/requirements"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "default": 0,
      "description": "Work priority (higher = more urgent)"
    },
    "assignedTo": {
      "type": ["string", "null"],
      "description": "Agent lane assigned (claude, gemini, codex, etc.)"
    },
    "assignedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When work was assigned to agent"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "assigned", "in_progress", "completed", "failed"],
      "description": "Work item status"
    },
    "branch": {
      "type": ["string", "null"],
      "description": "Git branch name (e.g., claude/issue-335)"
    },
    "targetDate": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Target completion date"
    },
    "retries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3,
      "default": 0,
      "description": "Number of retry attempts made"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "When work item was created"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "completedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When work was completed"
    },
    "result": {
      "type": ["object", "null"],
      "description": "Work completion result (PR URL, commit hash, etc.)"
    },
    "lastError": {
      "type": ["string", "null"],
      "description": "Last error message if failed"
    }
  },
  "examples": [
    {
      "id": "issue-335",
      "issueNumber": 335,
      "title": "Phase 2: Stage Routing & Loop Tracking",
      "description": "Implement 7-stage path and loop counter...",
      "priority": 5,
      "assignedTo": "claude",
      "assignedAt": "2026-06-13T10:00:00Z",
      "status": "in_progress",
      "branch": "claude/issue-335",
      "targetDate": "2026-06-15T00:00:00Z",
      "retries": 0,
      "createdAt": "2026-06-13T08:00:00Z",
      "updatedAt": "2026-06-13T10:00:00Z",
      "completedAt": null,
      "result": null,
      "lastError": null
    }
  ]
}
