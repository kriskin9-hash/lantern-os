# ─── Secrets & credentials ────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.secret
secrets/

# ─── Private / PII data (never commit) ────────────────────────────────────────
data/private/**
!data/private/
!data/private/README.md
private/**
.local-private/**

# Dreamer notebooks — private user data (local only)
data/dreamer/notebooks/*.jsonl
data/dream_journal/*.jsonl

# Discord subscriber data
data/discord/subscribers.json

# ─── Training outputs (review locally before promotion) ───────────────────────
data/training/**/*.jsonl
data/training/**/*.json
!data/training/**/README.md

# ─── Rust ─────────────────────────────────────────────────────────────────────
src/csf_rust/target/

# ─── Runtime state ────────────────────────────────────────────────────────────
data/pcsf/*.json
apps/data/conversations/garage-conversations.jsonl

# HFF runtime snapshot (generated by export_snapshot.py on boot)
integrations/human-flourishing-frameworks/data/snapshot.json
integrations/human-flourishing-frameworks/data/world_model.db

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
.pytest_cache/
*.pyc

# Discord subscriber data (local only, not in Git)
data/discord/subscribers.json

# Dreamer notebooks — private user data (local only)
data/dreamer/notebooks/*.jsonl

# Google Drive temp folders
.tmp.driveupload/
.tmp.drivedownload/
.claude/worktrees/
