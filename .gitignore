data/dream_journal/csf/*.csf
data/status/agent-monitor-latest.json
data/conversations/garage-conversations.jsonl
apps/data/conversations/garage-conversations.jsonl

# Deployment weight reduction (static site deploy)
.git/

# === Anti-bloat additions (2026-06-03) ===
# Temporary / one-off artifacts
*.md.bak
*HANDOFF*
*DEPLOYMENT-REPORT*
*PROGRESS-TRACKING*
.tmp-*/
archive/**/worktrees/**

# Old versioned files
*-v2*
*-v3*
*-old*
*-backup*

# IDE / tool artifacts
.claude/
.claude-plugin/
.vscode/
.windsurf/

# Generated artifacts
artifacts/
*.log
*.tmp

# Python cache
__pycache__/

# Data directories that should not be committed
data/dream_journal/
data/dollhouse/csf/
data/dollhouse/agent-checkin-manifest.json
data/agent-fleet/
data/provenance/

# Auto-generated convergence evidence files
manifests/evidence/convergence-*.json
convergence-output.json
data/pcsf/convergance-receipts.jsonl

# ─── Machine Learning Models & Training (2026-06-08) ───────────────────
# Generated door images from LoRA training
data/images/generated-doors/
data/images/**/*.png
data/images/**/*.jpg

# LoRA model checkpoints (train locally, commit final only)
data/models/lora/**/checkpoint-*.safetensors
data/models/lora/**/optimizer.pt
data/models/lora/**/*.bin
data/models/lora/**/training_args.bin
!data/models/lora/*/adapter_config.json
!data/models/lora/**/*-final.safetensors
!data/models/lora/**/README.md

# Training logs and artifacts
data/training_logs/
*.pth
*.ckpt

# Discord event data (local only)
data/discord/**/*.json
!data/discord/README.md
