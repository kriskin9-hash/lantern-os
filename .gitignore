# ─── Secrets & credentials ────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.secret
secrets/

# ─── Private / PII data (never commit) ────────────────────────────────────────
data/private/**
!data/private/
!data/private/README.md
private/**
.local-private/**

# Dreamer notebooks — private user data (local only)
data/dreamer/notebooks/*.jsonl
data/dream_journal/*.jsonl

# Discord subscriber data
data/discord/subscribers.json

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
.pytest_cache/
*.pyc

# ─── Build artifacts ──────────────────────────────────────────────────────────
artifacts/*
!artifacts/.gitkeep
data/dollhouse/csf/
data/agent-fleet/
_site/

# ─── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.tmp
*.log
*.swp
*.swo
*.orig
.idea/
.vscode/settings.json

# ─── Claude agent worktrees (ephemeral) ───────────────────────────────────────
.claude/worktrees/
.claude/

# ─── CI/build cache ───────────────────────────────────────────────────────────
.tmp.driveupload/
.tmp.drivedownload/
.tmp-*/
