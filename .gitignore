# Local/generated
*.log
*.tmp
__pycache__/
.venv/
*.egg-info/

# Secrets and local environment
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.secret
secrets/

# Private local vaults: never commit raw PIID/PII/private social/feed/patient data.
data/private/**
!data/private/
!data/private/README.md
private/**
.local-private/**

# Large promoted artifacts should be added intentionally with manifest updates.
artifacts/*
!artifacts/.gitkeep
# Node modules
node_modules/
**/node_modules/

# Python build artifacts
*.egg-info/
dist/
build/

# Discord subscriber data (local only, not in Git)
data/discord/subscribers.json

# Dreamer notebooks — private user data (local only)
data/dreamer/notebooks/*.jsonl

# Google Drive temp folders
.tmp.driveupload/
.tmp.drivedownload/
.claude/worktrees/
data/dream_journal/*.jsonl

# Deployment weight reduction (static site deploy)
.git/

# === Anti-bloat additions (2026-06-03) ===
# Temporary / one-off artifacts
*.md.bak
*HANDOFF*
*DEPLOYMENT-REPORT*
*PROGRESS-TRACKING*
.tmp-*/
archive/**/worktrees/**

# Old versioned files
*-v2*
*-v3*
*-old*
*-backup*

# IDE / tool artifacts
.claude/
.claude-plugin/
.vscode/
.windsurf/

# Generated artifacts
artifacts/
*.log
*.tmp

# Python cache
__pycache__/

# Data directories that should not be committed
data/dream_journal/
data/dollhouse/csf/
data/agent-fleet/
