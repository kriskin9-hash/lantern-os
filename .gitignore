# ─── Secrets & credentials ────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.secret
secrets/

# ─── Private / PII data (never commit) ────────────────────────────────────────
data/private/**
!data/private/
!data/private/README.md
private/**
.local-private/**

# Dreamer notebooks — private user data (local only)
data/dreamer/notebooks/*.jsonl
data/dream_journal/*.jsonl

# Discord subscriber data
data/discord/subscribers.json

# Legacy three-doors JSON state (replaced by CSF v07 — see data/csf/)
data/discord/three-doors/*.json

# Player CSF files — private ImagniVerse state (local only)
data/csf/*.csf

# Large local media (archived in D:\tmp / Google Drive)
apps/lantern-garage/public/data/video/*.mp4

# ─── Training outputs (review locally before promotion) ───────────────────────
data/training/**/*.jsonl
data/training/**/*.json
!data/training/**/README.md

# ─── Rust ─────────────────────────────────────────────────────────────────────
src/csf_rust/target/

# ─── Runtime state ────────────────────────────────────────────────────────────
data/pcsf/*.json
apps/data/conversations/garage-conversations.jsonl
data/metrics/three-doors-events.jsonl

# ─── Document ingest (generated, large, local-only) ──────────────────────────
data/csf-ingest/deltas.jsonl
data/csf-ingest/dedup-log.jsonl
data/file-uploads/

# Tesseract training data (large binary, downloaded at runtime)
*.traineddata

# HFF runtime snapshot (generated by export_snapshot.py on boot)
integrations/human-flourishing-frameworks/data/snapshot.json
integrations/human-flourishing-frameworks/data/world_model.db

# YouTube channel scrape cache (regenerated at runtime by routes/youtube.js;
# the route bakes its own fallback list, so none of this needs tracking)
data/youtube/

# CAAD grounding corpus — large external reference PDFs (315MB+) downloaded at
# runtime. Tracked spec lives under docs/caad/; the raw PDFs stay local-only.
caad/architecture/grounding/

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-error.log*
.pnp
.pnp.js

