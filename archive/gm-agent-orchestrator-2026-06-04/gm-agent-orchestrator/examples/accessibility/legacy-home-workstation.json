{
  "schemaVersion": 1,
  "surfaceId": "legacy-home-workstation",
  "profile": "legacy-home-accessibility",
  "targetHardware": {
    "os": "Windows 10 or Windows 11",
    "ramGb": "4-8",
    "gpuRequired": false,
    "microphone": "cheap USB headset or desktop mic",
    "display": "single 1080p monitor or lower",
    "optionalDevices": [
      "trackball",
      "vertical mouse",
      "large-print keyboard",
      "USB foot pedal",
      "macro keypad",
      "adaptive button"
    ]
  },
  "inputModes": [
    "keyboard",
    "mouse",
    "voice",
    "dictation",
    "large-button",
    "switch-compatible",
    "text-command"
  ],
  "outputModes": [
    "large-text",
    "high-contrast",
    "screen-reader-text",
    "read-aloud",
    "printable-checklist",
    "plain-text-summary"
  ],
  "safeActions": [
    "next",
    "back",
    "repeat",
    "read-aloud",
    "save",
    "help",
    "stop",
    "call-helper",
    "print-checklist"
  ],
  "blockedOneClickActions": [
    "send",
    "submit",
    "pay",
    "delete",
    "force-push",
    "start-agents",
    "move-queue"
  ],
  "capabilityHonesty": {
    "voiceUnavailableMessage": "Voice control is not available on this machine. You can continue with keyboard shortcuts, large buttons, or text commands.",
    "lowResolutionMessage": "This display is constrained, so Suzie switched to one-step mode.",
    "cloudBlockedMessage": "Cloud transcription is blocked by this profile. You can use local dictation if available or continue with text commands."
  },
  "missionCriticalSafeguards": {
    "confirmationRequiredFor": [
      "send",
      "submit",
      "pay",
      "delete",
      "external-contact",
      "queue-mutation",
      "agent-start"
    ],
    "fallbackRequired": true,
    "evidenceRequired": true,
    "singleInputDependencyAllowed": false
  }
}
