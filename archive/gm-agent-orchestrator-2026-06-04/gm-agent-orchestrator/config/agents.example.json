{
  "fallbackWaitMinutes": 300,
  "maxResumeCycles": 4,
  "slots": [
    {
      "name": "operator-intake",
      "agent": "human-interface",
      "role": "operator-intake",
      "enabled": true,
      "branch": "agent/operator-intake",
      "routing": {
        "directHumanRequestsFirst": true,
        "clarifiesAmbiguousRequests": true,
        "translatesToAuditableQueueTasks": true,
        "implementationEligible": false
      },
      "command": {
        "start": [
          "powershell",
          "-NoProfile",
          "-Command",
          "Write-Output 'operator intake queue requires explicit task creation'"
        ],
        "resume": [
          "powershell",
          "-NoProfile",
          "-Command",
          "Write-Output 'operator intake queue requires explicit task creation'"
        ]
      }
    },
    {
      "name": "codex-main",
      "agent": "codex",
      "role": "implementation",
      "enabled": true,
      "branch": "agent/codex-main",
      "command": {
        "start": [
          "codex",
          "exec",
          "{prompt}"
        ],
        "resume": [
          "codex",
          "exec",
          "resume",
          "--last",
          "{prompt}"
        ]
      }
    },
    {
      "name": "claude-main",
      "agent": "claude",
      "role": "implementation-review",
      "enabled": true,
      "branch": "agent/claude-main",
      "command": {
        "start": [
          "claude",
          "--print",
          "{prompt}"
        ],
        "resume": [
          "claude",
          "--continue",
          "--print",
          "{prompt}"
        ],
        "fallbackResume": [
          "claude",
          "-p",
          "--continue",
          "{prompt}"
        ]
      }
    },
    {
      "name": "gpt-web",
      "agent": "gpt-web",
      "role": "browser-fallback",
      "enabled": false,
      "branch": "agent/gpt-web",
      "command": {
        "start": [
          "powershell",
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "$task = '{task_path}'; if ([string]::IsNullOrWhiteSpace($task)) { throw 'Missing {task_path}; gpt-web requires an orchestrator-claimed active task.' }; $root = Split-Path -Parent (Split-Path -Parent (Split-Path -Parent $task)); & (Join-Path $root 'scripts\\Start-GptWebAgent.ps1') -Root $root -MaxTasks 1 -TaskFile $task"
        ],
        "resume": [
          "powershell",
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "$task = '{task_path}'; if ([string]::IsNullOrWhiteSpace($task)) { throw 'Missing {task_path}; gpt-web requires an orchestrator-claimed active task.' }; $root = Split-Path -Parent (Split-Path -Parent (Split-Path -Parent $task)); & (Join-Path $root 'scripts\\Start-GptWebAgent.ps1') -Root $root -MaxTasks 1 -TaskFile $task"
        ]
      }
    },
    {
      "name": "gemini-main",
      "agent": "gemini",
      "role": "research-validation",
      "enabled": false,
      "branch": "agent/gemini-main",
      "command": {
        "start": [
          "gemini",
          "-p",
          "{prompt}",
          "--model",
          "gemini-2.5-flash",
          "--skip-trust"
        ],
        "resume": [
          "gemini",
          "-p",
          "{prompt}",
          "--model",
          "gemini-2.5-flash",
          "--skip-trust"
        ]
      }
    }
  ]
}
