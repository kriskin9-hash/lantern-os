{
  "fallbackWaitMinutes": 300,
  "maxResumeCycles": 4,
  "slots": [
    {
      "name": "codex-main",
      "agent": "codex",
      "role": "implementation",
      "enabled": false,
      "branch": "agent/codex-main",
      "command": {
        "start": ["codex", "exec", "{prompt}"],
        "resume": ["codex", "exec", "resume", "--last", "{prompt}"]
      },
      "blocker": "native_windows_codex_blocked",
      "nextAction": "Do not route work to codex-main. Use WSL or repair Codex setup first."
    },
    {
      "name": "claude-main",
      "agent": "claude",
      "role": "implementation-review",
      "enabled": false,
      "branch": "agent/claude-main",
      "command": {
        "start": ["claude", "--dangerously-skip-permissions", "--print", "{prompt}"],
        "resume": ["claude", "--dangerously-skip-permissions", "--continue", "--print", "{prompt}"],
        "fallbackResume": ["claude", "--dangerously-skip-permissions", "-p", "--continue", "{prompt}"]
      }
    },
    {
      "name": "gemini-main",
      "agent": "gemini",
      "role": "research-validation",
      "enabled": false,
      "branch": "agent/gemini-main",
      "command": {
        "start": ["gemini", "-p", "{prompt}", "--skip-trust"],
        "resume": ["gemini", "-p", "{prompt}", "--skip-trust"]
      }
    },
    {
      "name": "headless",
      "agent": "openhands",
      "role": "implementation",
      "enabled": true,
      "branch": "agent/headless",
      "command": {
        "start": [
          "powershell",
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "C:\\Users\\alexp\\Documents\\gm-agent-orchestrator\\scripts\\Invoke-OpenHandsAgent.ps1",
          "--headless",
          "-t",
          "{prompt}"
        ],
        "resume": [
          "powershell",
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "C:\\Users\\alexp\\Documents\\gm-agent-orchestrator\\scripts\\Invoke-OpenHandsAgent.ps1",
          "--headless",
          "-t",
          "{prompt}"
        ]
      }
    },
    {
      "name": "deepseek-main",
      "agent": "deepseek",
      "role": "implementation",
      "enabled": false,
      "branch": "agent/deepseek-main",
      "command": {
        "start": ["claude", "--dangerously-skip-permissions", "--print", "{prompt}"],
        "resume": ["claude", "--dangerously-skip-permissions", "--continue", "--print", "{prompt}"]
      }
    },
    {
      "name": "gemini-flash",
      "agent": "gemini",
      "role": "research-validation",
      "enabled": false,
      "branch": "agent/gemini-flash",
      "command": {
        "start": ["gemini", "-p", "{prompt}", "--skip-trust"],
        "resume": ["gemini", "-p", "{prompt}", "--skip-trust"]
      }
    },
    {
      "name": "headless-2",
      "agent": "openhands",
      "role": "implementation",
      "enabled": false,
      "branch": "agent/headless-2",
      "command": {
        "start": ["openhands", "--headless", "-t", "{prompt}"],
        "resume": ["openhands", "--headless", "-t", "{prompt}"]
      }
    }
  ]
}