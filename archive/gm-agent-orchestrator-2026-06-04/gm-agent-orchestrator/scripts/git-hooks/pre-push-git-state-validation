#!/bin/bash
# pre-push-git-state-validation
# Enforce drift-prevention-contract.md Rule 2: Git State Validation
#
# Validates before push:
# - No uncommitted changes (working tree clean)
# - No dubious ownership or unsafe repo warnings
# - All branches have tracking info (no [gone])
# - All worktrees accounted for (paths exist)
# - No stale merged branches (older than 7 days)
#
# Exit codes:
#   0 = pass (all checks succeed)
#   1 = fail (violation detected, push blocked)

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
VIOLATIONS=0
BLOCKERS=()

echo "[pre-push] Git State Validation"

# Check 1: Working tree clean
echo -n "  Checking working tree... "
if ! git diff-index --quiet HEAD -- > /dev/null 2>&1; then
    echo "❌"
    BLOCKERS+=("Uncommitted changes exist (git status shows modifications)")
    VIOLATIONS=$((VIOLATIONS + 1))
else
    echo "✅"
fi

# Check 2: No dubious ownership or unsafe repo
echo -n "  Checking git ownership... "
if git fetch origin 2>&1 | grep -iE "dubious|unsafe|permission" > /tmp/ownership_$$.txt 2>&1; then
    if [ -s /tmp/ownership_$$.txt ]; then
        echo "❌"
        BLOCKERS+=("Git ownership issue detected: $(cat /tmp/ownership_$$.txt | head -1)")
        VIOLATIONS=$((VIOLATIONS + 1))
    else
        echo "✅"
    fi
else
    echo "✅"
fi

# Check 3: All branches have tracking info
echo -n "  Checking branch tracking... "
UNTRACKED=$(git branch -vv | grep '\[gone\]' | wc -l || true)
if [ "$UNTRACKED" -gt 0 ]; then
    echo "❌"
    BLOCKERS+=("$UNTRACKED branch(es) show [gone] — remote deleted, clean up locally with: git branch -D [name]")
    VIOLATIONS=$((VIOLATIONS + 1))
else
    echo "✅"
fi

# Check 4: Worktrees exist
echo -n "  Checking worktrees... "
MISSING_WORKTREES=0
while IFS= read -r line; do
    path=$(echo "$line" | awk '{print $1}')
    if [[ -n "$path" ]] && [[ "$path" != "$REPO_ROOT" ]] && [[ ! -d "$path" ]]; then
        BLOCKERS+=("Worktree path missing: $path (run: git worktree prune)")
        MISSING_WORKTREES=$((MISSING_WORKTREES + 1))
        VIOLATIONS=$((VIOLATIONS + 1))
    fi
done < <(git worktree list)

if [ $MISSING_WORKTREES -eq 0 ]; then
    echo "✅"
else
    echo "❌ ($MISSING_WORKTREES missing)"
fi

# Check 5: No stale merged branches (merged 7+ days ago, still local)
echo -n "  Checking for stale merged branches... "
STALE_COUNT=0
CUTOFF_DATE=$(date -d "7 days ago" +%s 2>/dev/null || date -v-7d +%s 2>/dev/null || echo "0")

if [ "$CUTOFF_DATE" != "0" ]; then
    while IFS= read -r branch; do
        if [[ -z "$branch" ]]; then
            continue
        fi
        # Get last commit date on this branch
        COMMIT_DATE=$(git log -1 --format=%ct "$branch" 2>/dev/null || echo "0")
        if [ "$COMMIT_DATE" != "0" ] && [ "$COMMIT_DATE" -lt "$CUTOFF_DATE" ]; then
            STALE_COUNT=$((STALE_COUNT + 1))
        fi
    done < <(git branch --merged master | grep -v '^\*' | grep -v '^  master$')
fi

if [ $STALE_COUNT -gt 0 ]; then
    echo "⚠️  ($STALE_COUNT stale)"
    echo "    Note: Stale merged branches detected. Clean up per agent-contract.md Phase 5."
else
    echo "✅"
fi

# Cleanup
rm -f /tmp/ownership_$$.txt

if [ $VIOLATIONS -gt 0 ]; then
    echo ""
    echo "❌ PUSH BLOCKED: $VIOLATIONS git state validation failure(s)"
    echo "   Rule: drift-prevention-contract.md Rule 2 (Git State Validation)"
    echo ""
    for blocker in "${BLOCKERS[@]}"; do
        echo "   • $blocker"
    done
    echo ""
    exit 1
fi

echo ""
echo "✅ Git state validation passed"
exit 0
