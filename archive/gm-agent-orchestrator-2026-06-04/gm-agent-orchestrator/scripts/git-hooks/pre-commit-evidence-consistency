#!/bin/bash
# pre-commit-evidence-consistency
# Enforce drift-prevention-contract.md Rule 1: Evidence Consistency
#
# Validates that modified/staged docs don't contain contradictions:
# - No "deprecated X" without removal date or "TBD"
# - No "feature removed" for features still in code
# - No conflicting version claims
# - All references include specific line numbers or timestamps
#
# Exit codes:
#   0 = pass (no contradictions found)
#   1 = fail (contradictions detected, commit blocked)
#   2 = skip (non-doc files only)

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
DOCS_DIR="$REPO_ROOT/docs"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# If no docs modified, pass
if ! echo "$STAGED_FILES" | grep -q "\.md$"; then
    exit 0
fi

STAGED_DOCS=$(echo "$STAGED_FILES" | grep "\.md$")
VIOLATIONS=0

echo "[pre-commit] Evidence Consistency Check"
echo "Checking $(echo "$STAGED_DOCS" | wc -l) modified docs..."

# Rule 1: Check for "deprecated" without removal date
while IFS= read -r doc; do
    if [[ ! -f "$doc" ]]; then
        continue
    fi

    # Find lines with "deprecated" or "removed" without a date or "TBD"
    if grep -n "deprecated\|removed" "$doc" | grep -v "2026-" | grep -v "TBD" > /tmp/violation_$$.txt 2>&1; then
        if [ -s /tmp/violation_$$.txt ]; then
            echo ""
            echo "❌ $doc: Ambiguous deprecation (no removal date or TBD):"
            cat /tmp/violation_$$.txt | head -5
            VIOLATIONS=$((VIOLATIONS + 1))
        fi
    fi
done <<< "$STAGED_DOCS"

# Rule 2: Check for vague references ("according to the docs", "the documentation says")
while IFS= read -r doc; do
    if [[ ! -f "$doc" ]]; then
        continue
    fi

    if grep -n "according to the docs\|the documentation says\|the docs describe" "$doc" > /tmp/vague_$$.txt 2>&1; then
        if [ -s /tmp/vague_$$.txt ]; then
            echo ""
            echo "⚠️  $doc: Vague reference (cite specific lines instead):"
            cat /tmp/vague_$$.txt | head -3
            echo "   Fix: Replace with 'docs/path.md (lines X-Y)' or 'commit abc123'"
            VIOLATIONS=$((VIOLATIONS + 1))
        fi
    fi
done <<< "$STAGED_DOCS"

# Rule 3: Check that file references exist
while IFS= read -r doc; do
    if [[ ! -f "$doc" ]]; then
        continue
    fi

    # Extract references like "docs/path.md"
    if grep -o 'docs/[a-zA-Z0-9_.-]*\.md' "$doc" | sort -u > /tmp/refs_$$.txt 2>&1; then
        while IFS= read -r ref; do
            if [[ -n "$ref" ]] && [[ ! -f "$REPO_ROOT/$ref" ]]; then
                echo ""
                echo "❌ $doc: Reference to non-existent file: $ref"
                VIOLATIONS=$((VIOLATIONS + 1))
            fi
        done < /tmp/refs_$$.txt
    fi
done <<< "$STAGED_DOCS"

# Cleanup
rm -f /tmp/violation_$$.txt /tmp/vague_$$.txt /tmp/refs_$$.txt

if [ $VIOLATIONS -gt 0 ]; then
    echo ""
    echo "❌ COMMIT BLOCKED: $VIOLATIONS evidence consistency violation(s) found"
    echo "   Rule: drift-prevention-contract.md Rule 1 (Evidence Consistency)"
    echo "   Action: Fix contradictions, add dates/TBD, cite specific lines"
    echo ""
    exit 1
fi

echo "✅ Evidence consistency check passed"
exit 0
