{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/capability-map.schema.json",
  "title": "CapabilityMap",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "capturedAt", "profile", "slots", "capabilities", "decisions"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "capturedAt": { "type": ["string", "null"], "format": "date-time" },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "minLength": 1 },
        "cloudAllowed": { "type": "boolean" },
        "approvalRequired": { "type": "boolean" }
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "provider", "model", "state", "tools"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "model": { "type": ["string", "null"] },
          "state": { "$ref": "#/$defs/capabilityState" },
          "reason": { "type": "string" },
          "tools": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "state", "sources"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "state": { "$ref": "#/$defs/capabilityState" },
          "sources": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "reason": { "type": "string" },
          "safeAlternative": { "type": "string" }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["taskType", "decision", "reason"],
        "properties": {
          "taskType": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "enum": ["allow", "degrade", "decline", "needs-preflight", "needs-approval"] },
          "reason": { "type": "string", "minLength": 1 },
          "recommendedSlot": { "type": ["string", "null"] },
          "safeAlternative": { "type": ["string", "null"] }
        }
      }
    }
  },
  "$defs": {
    "capabilityState": {
      "type": "string",
      "enum": ["available", "degraded", "blocked", "unverified", "unavailable", "unsafe"]
    }
  }
}
