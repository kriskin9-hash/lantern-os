{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lantern-os.local/schemas/claim-packet.v1.json",
  "title": "Lantern OS Claim Packet v1",
  "description": "Smallest shareable unit of community learning. A claim packet is evidence-backed, uncertainty-marked, and consent-gated before it ever reaches the mesh or a World Cube.",
  "type": "object",
  "required": [
    "schema",
    "packet_id",
    "created_at",
    "origin",
    "claim",
    "measurement",
    "evidence",
    "privacy",
    "risk",
    "review",
    "signature"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "lantern.claim_packet.v1",
      "description": "Schema discriminator. Must be exactly 'lantern.claim_packet.v1'."
    },
    "packet_id": {
      "type": "string",
      "pattern": "^claim:[a-f0-9-]+$",
      "description": "Globally unique packet id. Format: claim:<uuid>."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of packet creation."
    },

    "origin": {
      "type": "object",
      "required": ["node_id", "software", "software_version", "operator_approved"],
      "properties": {
        "node_id": {
          "type": "string",
          "pattern": "^node:[a-zA-Z0-9._-]+$",
          "description": "Node identifier. May be hashed or public."
        },
        "software": {
          "type": "string",
          "const": "lantern-os",
          "description": "Software producing this packet."
        },
        "software_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of Lantern OS."
        },
        "operator_approved": {
          "type": "boolean",
          "description": "False until Consent Gate approval."
        }
      },
      "additionalProperties": false
    },

    "claim": {
      "type": "object",
      "required": ["title", "kind", "safe_wording", "scope", "domain", "flourishing_dimensions"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Human-readable summary of the claim."
        },
        "kind": {
          "type": "string",
          "enum": ["measurement", "intervention", "pattern", "challenge"],
          "description": "What kind of claim this packet makes."
        },
        "safe_wording": {
          "type": "string",
          "minLength": 10,
          "description": "Conservative phrasing. No causal certainty. Example: 'In this local node, X was associated with Y during the observation window.'"
        },
        "scope": {
          "type": "string",
          "pattern": "^[a-z_]+:[a-z_]+$",
          "description": "Scope tag. Format: category:subcategory. Example: household:pet-care, garden:watering."
        },
        "domain": {
          "type": "string",
          "enum": [
            "animal_welfare",
            "human_health",
            "human_autonomy",
            "human_fairness",
            "human_opportunity",
            "ecology",
            "education",
            "creative_flourishing",
            "community_trust",
            "unspecified"
          ],
          "description": "Primary flourishing domain."
        },
        "flourishing_dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "animal_health",
              "animal_safety",
              "animal_comfort",
              "animal_natural_behavior",
              "human_health",
              "human_autonomy",
              "human_fairness",
              "human_opportunity",
              "ecosystem_biodiversity",
              "ecosystem_stability",
              "ecosystem_resilience",
              "creative_flourishing",
              "community_trust",
              "routine_stability"
            ]
          },
          "description": "Specific flourishing dimensions this claim touches."
        }
      },
      "additionalProperties": false
    },

    "measurement": {
      "type": "object",
      "required": [
        "value",
        "uncertainty",
        "confidence_interval",
        "sample_size",
        "source",
        "methodology",
        "temporal_range",
        "scope",
        "confounders",
        "missing",
        "measurement_hash"
      ],
      "properties": {
        "value": {
          "description": "The observed quantity. Can be any JSON-serializable value."
        },
        "uncertainty": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "0.0 = certain (almost never true). 1.0 = no idea."
        },
        "confidence_interval": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "number" },
          "description": "[lower, upper] bounds."
        },
        "sample_size": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of observations."
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "description": "Provenance: URL, dataset, sensor id, or 'local_node'."
        },
        "methodology": {
          "type": "string",
          "minLength": 1,
          "description": "How the value was collected: 'operator_logged_events', 'sensor_reading', 'survey', etc."
        },
        "temporal_range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "pattern": "^(\\d{4}-\\d{2}-\\d{2}|unknown)$"
          },
          "description": "[start_date, end_date] in ISO-8601."
        },
        "scope": {
          "type": "string",
          "minLength": 1,
          "description": "Population this measurement applies to. Must match claim.scope or be a sub-scope."
        },
        "confounders": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known factors that could explain the observed effect."
        },
        "missing": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known gaps in coverage or methodology."
        },
        "measurement_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 of canonical measurement representation for tamper detection."
        }
      },
      "additionalProperties": false
    },

    "evidence": {
      "type": "object",
      "required": ["evidence_class", "certainty", "replication_status", "source_refs", "status_cube_refs"],
      "properties": {
        "evidence_class": {
          "type": "string",
          "enum": ["local_pilot", "repeated_observation", "controlled_test", "peer_reviewed", "community_replicated", "synthetic_demo"],
          "description": "Rigor tier of the evidence."
        },
        "certainty": {
          "type": "string",
          "enum": ["none", "very_low", "low", "moderate", "high", "very_high"],
          "description": "Human-assessed certainty label."
        },
        "replication_status": {
          "type": "string",
          "enum": ["not_replicated", "single_replication", "multiple_replications", "community_supported"],
          "description": "How many independent nodes have reported similar findings."
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "External references: DOIs, URLs, dataset names."
        },
        "status_cube_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Internal StatusCube artifact ids or coordinates that support this claim."
        }
      },
      "additionalProperties": false
    },

    "privacy": {
      "type": "object",
      "required": ["raw_private_data_included", "privacy_level", "allowed_use", "revocable", "expires_at"],
      "properties": {
        "raw_private_data_included": {
          "type": "boolean",
          "description": "Must be false for any mesh export. True blocks export."
        },
        "privacy_level": {
          "type": "string",
          "enum": ["raw_private", "anonymized", "aggregated", "public"],
          "description": "Current privacy treatment."
        },
        "allowed_use": {
          "type": "string",
          "enum": ["aggregate_pattern_only", "research_review", "peer_mesh", "unrestricted"],
          "description": "What downstream uses are permitted."
        },
        "revocable": {
          "type": "boolean",
          "description": "Can the operator later revoke this packet?"
        },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "Optional automatic expiration. Null means no expiry."
        }
      },
      "additionalProperties": false
    },

    "risk": {
      "type": "object",
      "required": ["risk_class", "sensitive", "automation_allowed", "recommendation_allowed"],
      "properties": {
        "risk_class": {
          "type": "string",
          "enum": ["trivial", "low", "moderate", "high", "blocked"],
          "description": "Risk tier. 'blocked' prevents any downstream use."
        },
        "sensitive": {
          "type": "boolean",
          "description": "True if this touches people, medical, financial, or legal domains."
        },
        "automation_allowed": {
          "type": "boolean",
          "description": "Whether this claim can trigger local automation."
        },
        "recommendation_allowed": {
          "type": "boolean",
          "description": "Whether this claim can feed into community recommendations."
        }
      },
      "additionalProperties": false
    },

    "review": {
      "type": "object",
      "required": ["consent_gate_status", "reviewer", "reviewed_at", "challenge_path", "rollback_path"],
      "properties": {
        "consent_gate_status": {
          "type": "string",
          "enum": ["draft", "pending_review", "approved", "rejected", "revoked", "blocked"],
          "description": "Current Consent Gate state. Only 'approved' may leave the node."
        },
        "reviewer": {
          "type": "string",
          "description": "Who reviewed this: 'local_operator', 'lantern_agent', or a person id."
        },
        "reviewed_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When review occurred. Null if not yet reviewed."
        },
        "challenge_path": {
          "type": "boolean",
          "description": "Whether a challenge mechanism exists for this claim."
        },
        "rollback_path": {
          "type": "boolean",
          "description": "Whether the operator can undo the effects of sharing this claim."
        }
      },
      "additionalProperties": false
    },

    "signature": {
      "type": "object",
      "required": ["algorithm", "public_key", "signature"],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "ed25519",
          "description": "Signing algorithm. Only Ed25519 is supported in v1."
        },
        "public_key": {
          "type": "string",
          "pattern": "^ed25519:[A-Za-z0-9+/=]+$",
          "description": "Base64-encoded Ed25519 public key with algorithm prefix."
        },
        "signature": {
          "type": ["string", "null"],
          "pattern": "^[A-Za-z0-9+/=]*$",
          "description": "Base64-encoded signature over the canonical packet bytes. Null until signed."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
