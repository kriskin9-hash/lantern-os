# Lantern Garage Full-Stack App
# Novel Kubernetes deployment for convergence infrastructure
# Generated: 2026-05-27

FROM node:18-alpine

LABEL maintainer="Lantern OS"
LABEL version="1.0.0"
LABEL narrative="COMET-LEAPER-Operating-Narrative-v1"

WORKDIR /app

# Copy package files
COPY apps/lantern-garage/package.json .
COPY apps/lantern-garage/package-lock.json* .

# Install dependencies
RUN npm ci --only=production

# Copy application code
COPY apps/lantern-garage/server.js .
COPY apps/lantern-garage/validate.js .
COPY apps/lantern-garage/public/ ./public/

# Create data directories
RUN mkdir -p /data/rag-house /data/wallet /data/manifests

# Expose port
EXPOSE 4177

# Environment
ENV NODE_ENV=production
ENV LANTERN_MODE=convergence-loop
ENV NARRATIVE_MODE=COMET-LEAPER
ENV RAG_HOUSE_PATH=/data/rag-house/
ENV WALLET_PATH=/data/wallet/

# Health check
HEALTHCHECK --interval=10s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:4177/api/health', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})"

# Run application
CMD ["node", "server.js"]
