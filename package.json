{
  "name": "lantern-os",
  "version": "1.7.29",
  "private": true,
  "description": "Lantern OS — Dream Journal",
  "scripts": {
    "setup": "node scripts/ensure-rust.js && node scripts/build-csf-rust.js",
    "postinstall": "npm run setup",
    "start": "node apps/lantern-garage/server.js",
    "dev": "node apps/lantern-garage/server.js",
    "convergance": "bash scripts/git-convergance-loop.sh foreground",
    "setup:convergance": "bash scripts/setup-git-convergance-loop.sh",
    "research-nightly": "node scripts/open-video-research.js --nightly",
    "research-calibrate": "node scripts/open-video-research.js --calibrate",
    "test:ui": "node tests/ui-test.js",
    "creator-intelligence": "node scripts/creator-intelligence-loop.js --forever"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "busboy": "^1.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0"
  }
}
