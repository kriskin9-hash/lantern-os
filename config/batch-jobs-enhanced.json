{
  "schema": "lantern.batch_jobs.v2",
  "description": "Automated batch jobs for Lantern OS with CI/CD integration and mutual validation",
  "updatedAt": "2026-06-02",
  "version": "2.0",
  "enabledByDefault": true,
  "mutualValidation": true,
  "jobs": [
    {
      "id": "health-check",
      "name": "System Health Check",
      "script": "scripts/Invoke-HealthCheck.ps1",
      "args": [],
      "enabled": true,
      "priority": 0,
      "intervalMinutes": 10,
      "group": "health",
      "receiptClass": "health_check",
      "failurePolicy": "log",
      "description": "Verify Lantern Garage is responding and CI/CD infrastructure is healthy"
    },
    {
      "id": "validate-cicd",
      "name": "Validate CI/CD Pipeline",
      "script": "scripts/Validate-CicdPipeline.ps1",
      "args": ["-GitHubRepo", "alex-place/lantern-os"],
      "enabled": true,
      "priority": 1,
      "intervalMinutes": 30,
      "group": "validation",
      "receiptClass": "cicd_validation",
      "failurePolicy": "warn",
      "runAfter": ["health-check"],
      "description": "Validate that CI workflow exists, runs, and completes successfully. Batch jobs validate CI/CD."
    },
    {
      "id": "validate-batch-framework",
      "name": "Validate Batch Framework",
      "script": "scripts/Validate-BatchFramework.ps1",
      "args": ["-ConfigPath", "config/batch-jobs-enhanced.json"],
      "enabled": true,
      "priority": 2,
      "intervalMinutes": 60,
      "group": "validation",
      "receiptClass": "batch_framework_validation",
      "failurePolicy": "warn",
      "runAfter": ["validate-cicd"],
      "description": "Validate batch job configuration, schema, and execution readiness. CI/CD validates batch framework."
    },
    {
      "id": "test-mutual-validation",
      "name": "Test Mutual Validation Loop",
      "script": "scripts/Test-MutualValidation.ps1",
      "args": ["-LogPath", "data/automation/logs"],
      "enabled": true,
      "priority": 3,
      "intervalMinutes": 120,
      "group": "validation",
      "receiptClass": "mutual_validation_test",
      "failurePolicy": "warn",
      "runAfter": ["validate-batch-framework"],
      "description": "Test that CI/CD and batch framework successfully validate each other"
    },
    {
      "id": "convergence-loop",
      "name": "Convergence Loop (Daily)",
      "script": "scripts/Invoke-LanternConvergenceLoop.ps1",
      "args": [],
      "enabled": true,
      "priority": 10,
      "intervalMinutes": 1440,
      "group": "core",
      "receiptClass": "convergence_loop_run",
      "failurePolicy": "warn",
      "runAfter": ["validate-batch-framework"],
      "description": "Daily convergence: reconcile repo state, update RAG, generate reports"
    },
    {
      "id": "loop-receipt",
      "name": "Loop Receipt Generator",
      "script": "scripts/Invoke-LoopReceipt.ps1",
      "args": [],
      "enabled": true,
      "priority": 11,
      "intervalMinutes": 1440,
      "group": "evidence",
      "receiptClass": "convergence_loop_receipt",
      "failurePolicy": "warn",
      "runAfter": ["convergence-loop"],
      "description": "Generate daily receipt documenting convergence results"
    },
    {
      "id": "asset-discovery",
      "name": "Asset Discovery Engine",
      "script": "scripts/Invoke-AssetDiscoveryEngine.ps1",
      "args": ["-RunOnce"],
      "enabled": true,
      "priority": 20,
      "intervalMinutes": 2880,
      "group": "discovery",
      "receiptClass": "asset_discovery_run",
      "failurePolicy": "warn",
      "description": "Scan repo for new assets, skills, and documentation (runs every 2 days)"
    },
    {
      "id": "sync-rag-pdf",
      "name": "RAG + PDF Sync",
      "script": "scripts/Sync-RagAndPdf.ps1",
      "args": ["-SkipStyle"],
      "enabled": true,
      "priority": 30,
      "intervalMinutes": 4320,
      "group": "publish",
      "receiptClass": "sync_rag_pdf",
      "failurePolicy": "warn",
      "description": "Publish RAG flat files and generate PDF reports (runs every 3 days)"
    },
    {
      "id": "post-ingestion-purge",
      "name": "Post-Ingestion Purge",
      "script": "scripts/Invoke-PostIngestionPurge.ps1",
      "args": ["-ReportPdfRetentionDays", "7", "-MaxReceiptsPerClass", "30"],
      "enabled": true,
      "priority": 40,
      "intervalMinutes": 4800,
      "runAfter": ["sync-rag-pdf"],
      "group": "purge",
      "receiptClass": "post_ingestion_purge",
      "failurePolicy": "warn",
      "note": "Purges reports older than 7 days, evidence receipts beyond 30/class, superseded snapshots"
    },
    {
      "id": "generate-confidence-report",
      "name": "Generate Confidence Report",
      "script": "scripts/Build-LanternConfidenceReport.ps1",
      "args": ["-LanternRoot", ".", "-OutputPath", "manifests/validation/LANTERN-CONFIDENCE-LATEST.json"],
      "enabled": true,
      "priority": 50,
      "intervalMinutes": 10080,
      "group": "reports",
      "receiptClass": "confidence_report",
      "failurePolicy": "warn",
      "runAfter": ["loop-receipt"],
      "description": "Generate operator confidence report on feature readiness (weekly)"
    }
  ],
  "groups": {
    "health": { "description": "System health and readiness checks" },
    "validation": { "description": "Batch and CI/CD mutual validation" },
    "core": { "description": "Core convergence and reconciliation" },
    "evidence": { "description": "Receipt and evidence generation" },
    "discovery": { "description": "Asset and repo scanning" },
    "publish": { "description": "PDF and RAG flat-file publishing" },
    "purge": { "description": "Data retention and cleanup" },
    "reports": { "description": "Confidence and status reports" }
  },
  "defaults": {
    "failurePolicy": "warn",
    "timeoutSeconds": 300,
    "logDir": "data/automation/logs",
    "receiptDir": "manifests/evidence"
  },
  "mutualValidationConfig": {
    "enabled": true,
    "cicdValidatesEvery": "batch job",
    "batchValidatesEvery": "cicd workflow",
    "feedbackLoop": "continuous",
    "selfHealing": true,
    "description": "CI/CD and batch framework validate each other continuously. If either fails, both signal alert but continue operating."
  }
}
