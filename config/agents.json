{
  "version": "2.0.0",
  "description": "Lantern OS Diverse 36-Slot Convergence Fleet — claude, codex, gemini, devin distributed across 12 steps",
  "designedRingSlots": 36,
  "elasticPoolTarget": 64,
  "fleetClaimBoundary": "design contract only; live worker counts require local orchestrator evidence",
  "diversityPolicy": "Each of the 12 convergence steps carries 3 slots with 3 different agent types. No single agent failure can block a step.",
  "slots": [
    { "name": "s01-primary",  "agent": "claude", "role": "repo-state-inspector",       "enabled": true, "mode": "sleep", "step": 1, "branch": "fleet/s01-claude",  "command": { "start": ["claude", "--dangerously-skip-permissions", "{prompt}"], "resume": ["claude", "--dangerously-skip-permissions", "{prompt}"] } },
    { "name": "s01-backup-a", "agent": "codex",  "role": "git-status-verifier",        "enabled": true, "mode": "sleep", "step": 1, "branch": "fleet/s01-codex",   "command": { "start": ["codex", "{prompt}"], "resume": ["codex", "{prompt}"] } },
    { "name": "s01-backup-b", "agent": "gemini", "role": "file-surface-verifier",      "enabled": true, "mode": "sleep", "step": 1, "branch": "fleet/s01-gemini",  "command": { "start": ["gemini", "-p", "{prompt}", "--skip-trust"], "resume": ["gemini", "-p", "{prompt}", "--skip-trust"] } },
    { "name": "s02-primary",  "agent": "codex",  "role": "source-repo-scout",          "enabled": true, "mode": "sleep", "step": 2, "branch": "fleet/s02-codex",   "command": { "start": ["codex", "{prompt}"], "resume": ["codex", "{prompt}"] } },
    { "name": "s02-backup-a", "agent": "gemini", "role": "dirty-state-checker",        "enabled": true, "mode": "sleep", "step": 2, "branch": "fleet/s02-gemini",  "command": { "start": ["gemini", "-p", "{prompt}", "--skip-trust"], "resume": ["gemini", "-p", "{prompt}", "--skip-trust"] } },
    { "name": "s02-backup-b", "agent": "devin",  "role": "dependency-boundary-checker","enabled": true, "mode": "sleep", "step": 2, "branch": "fleet/s02-devin",   "command": { "start": ["devin", "{prompt}"], "resume": ["devin", "{prompt}"] } },
    { "name": "s03-primary",  "agent": "gemini", "role": "manifest-reader",            "enabled": true, "mode": "sleep", "step": 3, "branch": "fleet/s03-gemini",  "command": { "start": ["gemini", "-p", "{prompt}", "--skip-trust"], "resume": ["gemini", "-p", "{prompt}", "--skip-trust"] } },
    { "name": "s03-backup-a", "agent": "devin",  "role": "open-issue-reader",          "enabled": true, "mode": "sleep", "step": 3, "branch": "fleet/s03-devin",   "command": { "start": ["devin", "{prompt}"], "resume": ["devin", "{prompt}"] } },
    { "name": "s03-backup-b", "agent": "claude", "role": "stale-reference-checker",    "enabled": true, "mode": "sleep", "step": 3, "branch": "fleet/s03-claude",  "command": { "start": ["claude", "--dangerously-skip-permissions", "{prompt}"], "resume": ["claude", "--dangerously-skip-permissions", "{prompt}"] } },
    { "name": "s04-primary",  "agent": "devin",  "role": "objective-framer",           "enabled": true, "mode": "sleep", "step": 4, "branch": "fleet/s04-devin",   "command": { "start": ["devin", "{prompt}"], "resume": ["devin", "{prompt}"] } },
    { "name": "s04-backup-a", "agent": "claude", "role": "safety-reviewer",            "enabled": true, "mode": "sleep", "step": 4, "branch": "fleet/s04-claude",  "command": { "start": ["claude", "--dangerously-skip-permissions", "{prompt}"], "resume": ["claude", "--dangerously-skip-permissions", "{prompt}"] } },
    { "name": "s04-backup-b", "agent": "codex",  "role": "founder-priority-resolver",  "enabled": true, "mode": "sleep", "step": 4, "branch": "fleet/s04-codex",   "command": { "start": ["codex", "{prompt}"], "resume": ["codex", "{prompt}"] } },
    { "name": "s05-primary",  "agent": "claude", "role": "retirement-agent",           "enabled": true, "mode": "sleep", "step": 5, "branch": "fleet/s05-claude",  "command": { "start": ["claude", "--dangerously-skip-permissions", "{prompt}"], "resume": ["claude", "--dangerously-skip-permissions", "{prompt}"] } },
    { "name": "s05-backup-a", "agent": "codex",  "role": "deprecated-surface-checker", "enabled": true, "mode": "sleep", "step": 5, "branch": "fleet/s05-codex",   "command": { "start": ["codex", "{prompt}"], "resume": ["codex", "{prompt}"] } },
    { "name": "s05-backup-b", "agent": "gemini", "role": "quarantine-stub-checker",    "enabled": true, "mode": "sleep", "step": 5, "branch": "fleet/s05-gemini",  "command": { "start": ["gemini", "-p", "{prompt}", "--skip-trust"], "resume": ["gemini", "-p", "{prompt}", "--skip-trust"] } },
    { "name": "s06-primary",  "agent": "codex",  "role": "claim-mapper",               "enabled": true, "mode": "sleep", "step": 6, "branch": "fleet/s06-codex",   "command": { "start": ["codex", "{prompt}"], "resume": ["codex", "{prompt}"] } },
    { "name": "s06-backup-a", "agent": "gemini", "role": "evidence-linker",            "enabled": true, "mode": "sleep", "step": 6, "branch": "fleet/s06-gemini",  "command": { "start": ["gemini", "-p", "{prompt}", "--skip-trust"], "resume": ["gemini", "-p", "{prompt}", "--skip-trust"] } },
    { "name": "s06-backup-b", "agent": "devin",  "role": "confidence-classifier",      "enabled": true, "mode": "sleep", "step": 6, "branch": "fleet/s06-devin",   "command": { "start": ["devin", "{prompt}"], "resume": ["devin", "{prompt}"] } },
    { "name": "s07-primary",  "agent": "gemini", "role": "boundary-classifier",        "enabled": true, "mode": "sleep", "step": 7, "branch": "fleet/s07-gemini",  "command": { "start": ["gemini", "-p", "{prompt}", "--skip-trust"], "resume": ["gemini", "-p", "{prompt}", "--skip-trust"] } },
    { "name": "s07-backup-a", "agent": "devin",  "role": "rollback-checker",           "enabled": true, "mode": "sleep", "step": 7, "branch": "fleet/s07-devin",   "command": { "start": ["devin", "{prompt}"], "resume": ["devin", "{prompt}"] } },
    { "name": "s07-backup-b", "agent": "claude", "role": "capability-state-checker",   "enabled": true, "mode": "sleep", "step": 7, "branch": "fleet/s07-claude",  "command": { "start": ["claude", "--dangerously-skip-permissions", "{prompt}"], "resume": ["claude", "--dangerously-skip-permissions", "{prompt}"] } },
    { "name": "s08-primary",  "agent": "devin",  "role": "validation-runner",          "enabled": true, "mode": "sleep", "step": 8, "branch": "fleet/s08-devin",   "command": { "start": ["devin", "{prompt}"], "resume": ["devin", "{prompt}"] } },
    { "name": "s08-backup-a", "agent": "claude", "role": "cheapest-check-selector",    "enabled": true, "mode": "sleep", "step": 8, "branch": "fleet/s08-claude",  "command": { "start": ["claude", "--dangerously-skip-permissions", "{prompt}"], "resume": ["claude", "--dangerously-skip-permissions", "{prompt}"] } },
    { "name": "s08-backup-b", "agent": "codex",  "role": "environment-limit-recorder", "enabled": true, "mode": "sleep", "step": 8, "branch": "fleet/s08-codex",   "command": { "start": ["codex", "{prompt}"], "resume": ["codex", "{prompt}"] } },
    { "name": "s09-primary",  "agent": "claude", "role": "fix-agent",                  "enabled": true, "mode": "sleep", "step": 9, "branch": "fleet/s09-claude",  "command": { "start": ["claude", "--dangerously-skip-permissions", "{prompt}"], "resume": ["claude", "--dangerously-skip-permissions", "{prompt}"] } },
    { "name": "s09-backup-a", "agent": "codex",  "role": "backup-fixer",               "enabled": true, "mode": "sleep", "step": 9, "branch": "fleet/s09-codex",   "command": { "start": ["codex", "{prompt}"], "resume": ["codex", "{prompt}"] } },
    { "name": "s09-backup-b", "agent": "gemini", "role": "patch-risk-reviewer",        "enabled": true, "mode": "sleep", "step": 9, "branch": "fleet/s09-gemini",  "command": { "start": ["gemini", "-p", "{prompt}", "--skip-trust"], "resume": ["gemini", "-p", "{prompt}", "--skip-trust"] } },
    { "name": "s10-primary",  "agent": "codex",  "role": "revalidation-agent",         "enabled": true, "mode": "sleep", "step": 10, "branch": "fleet/s10-codex",  "command": { "start": ["codex", "{prompt}"], "resume": ["codex", "{prompt}"] } },
    { "name": "s10-backup-a", "agent": "gemini", "role": "regression-checker",         "enabled": true, "mode": "sleep", "step": 10, "branch": "fleet/s10-gemini", "command": { "start": ["gemini", "-p", "{prompt}", "--skip-trust"], "resume": ["gemini", "-p", "{prompt}", "--skip-trust"] } },
    { "name": "s10-backup-b", "agent": "devin",  "role": "receipt-checker",            "enabled": true, "mode": "sleep", "step": 10, "branch": "fleet/s10-devin",  "command": { "start": ["devin", "{prompt}"], "resume": ["devin", "{prompt}"] } },
    { "name": "s11-primary",  "agent": "gemini", "role": "evidence-recorder",          "enabled": true, "mode": "sleep", "step": 11, "branch": "fleet/s11-gemini", "command": { "start": ["gemini", "-p", "{prompt}", "--skip-trust"], "resume": ["gemini", "-p", "{prompt}", "--skip-trust"] } },
    { "name": "s11-backup-a", "agent": "devin",  "role": "blocker-recorder",           "enabled": true, "mode": "sleep", "step": 11, "branch": "fleet/s11-devin",  "command": { "start": ["devin", "{prompt}"], "resume": ["devin", "{prompt}"] } },
    { "name": "s11-backup-b", "agent": "claude", "role": "memory-rag-updater",         "enabled": true, "mode": "sleep", "step": 11, "branch": "fleet/s11-claude", "command": { "start": ["claude", "--dangerously-skip-permissions", "{prompt}"], "resume": ["claude", "--dangerously-skip-permissions", "{prompt}"] } },
    { "name": "s12-primary",  "agent": "devin",  "role": "promotion-judge",            "enabled": true, "mode": "sleep", "step": 12, "branch": "fleet/s12-devin",  "command": { "start": ["devin", "{prompt}"], "resume": ["devin", "{prompt}"] } },
    { "name": "s12-backup-a", "agent": "claude", "role": "hold-reject-judge",          "enabled": true, "mode": "sleep", "step": 12, "branch": "fleet/s12-claude", "command": { "start": ["claude", "--dangerously-skip-permissions", "{prompt}"], "resume": ["claude", "--dangerously-skip-permissions", "{prompt}"] } },
    { "name": "s12-backup-b", "agent": "codex",  "role": "founder-approval-router",    "enabled": true, "mode": "sleep", "step": 12, "branch": "fleet/s12-codex",  "command": { "start": ["codex", "{prompt}"], "resume": ["codex", "{prompt}"] } }
  ]
}
