{
  "app_name": "Lantern OS",
  "app_url": "https://lantern-os-production.up.railway.app",
  "app_description": "Lantern OS is a local-first AI operating system for human flourishing. It provides agent orchestration, MCP (Model Context Protocol) source management, fleet health monitoring, and human trial demo readiness tracking with strict safety boundaries.",
  "app_category": "Developer Tools",
  "app_icon": "https://lantern-os-production.up.railway.app/static/icon.png",
  "contact_email": "alex@lantern-os.io",
  "privacy_policy_url": "https://lantern-os-production.up.railway.app/privacy",
  "terms_of_service_url": "https://lantern-os-production.up.railway.app/terms",
  
  "oauth_configuration": {
    "client_name": "Lantern OS",
    "redirect_uris": [
      "https://lantern-os-production.up.railway.app/auth/callback",
      "http://localhost:3000/auth/callback"
    ],
    "scopes": ["read:user", "read:org"],
    "token_endpoint_auth_method": "client_secret_post"
  },
  
  "mcp_server_configuration": {
    "name": "Lantern OS Official",
    "description": "Official Lantern OS MCP server providing access to fleet health, readiness tracking, and agent orchestration endpoints",
    "sse_endpoint": "https://lantern-os-production.up.railway.app/sse",
    "health_endpoint": "https://lantern-os-production.up.railway.app/health",
    "supported_transports": ["sse", "http"],
    "authentication": {
      "type": "oauth_github",
      "provider": "github",
      "scopes": ["read:user", "read:org"]
    },
    "tools": [
      {
        "name": "account_connectivity",
        "description": "Check credentials present and reachable"
      },
      {
        "name": "open_orders",
        "description": "List resting orders only"
      },
      {
        "name": "open_positions",
        "description": "Show current holdings"
      },
      {
        "name": "recent_fills",
        "description": "List last 20 executed trades"
      },
      {
        "name": "settlement_warnings",
        "description": "Flag voided, disputed, or pending settlements"
      }
    ]
  },
  
  "capabilities": {
    "supports_streaming": true,
    "supports_function_calling": true,
    "supports_vision": false,
    "max_tokens": 128000
  },
  
  "safety_boundaries": {
    "allow_tool_execution": false,
    "local_only_modes_available": true,
    "operator_approval_required": true,
    "live_kill_switch": true,
    "demo_environment_default": true
  },
  
  "version": "1.0.0",
  "status": "staging",
  "operator_approved": "2026-05-31",
  "operator": "Alex Place"
}
