{
  "agents": [
    {
      "id": "agent_001",
      "name": "Dream Journal",
      "type": "dream_journal",
      "port": 5000,
      "status": "sleeping",
      "command": "python -m lantern_os.services.dream_journal --port {port} --name {name}",
      "memory_limit_mb": 256,
      "timeout_seconds": 300,
      "healthcheck": {
        "endpoint": "http://localhost:{port}/health",
        "interval_seconds": 30,
        "timeout_seconds": 5
      }
    },
