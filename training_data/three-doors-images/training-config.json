{
  "training_task": "image-to-caption-generation",
  "models_to_train": [
    "three-doors-image-classifier",
    "three-doors-caption-generator",
    "three-doors-stable-diffusion-lora"
  ],
  "dataset": {
    "name": "three-doors-visual",
    "total_images": 390,
    "train_count": 312,
    "val_count": 39,
    "test_count": 39,
    "categories": [
      "unknown",
      "door",
      "garden"
    ]
  },
  "training_params": {
    "image_classifier": {
      "model": "resnet50-pretrained",
      "epochs": 10,
      "batch_size": 32,
      "learning_rate": 0.0001
    },
    "caption_generator": {
      "model": "blip-image-captioning",
      "epochs": 5,
      "batch_size": 16,
      "learning_rate": 5e-05
    },
    "stable_diffusion_lora": {
      "base_model": "stabilityai/stable-diffusion-xl-base-1.0",
      "epochs": 3,
      "batch_size": 4,
      "learning_rate": 0.0001,
      "lora_rank": 16
    }
  }
}