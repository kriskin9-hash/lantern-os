# Lantern OS Headless Reverse Proxy
# No frills. Just routes.

:80 {
    # Health check endpoint
    respond /health 200

    # Dream Journal API
    handle_path /journal/* {
        reverse_proxy dream-journal:5000
    }

    # CSF compression API
    handle_path /csf/* {
        reverse_proxy csf-worker:9000
    }

    # Default
    respond "Lantern OS — headless mode" 200
}
