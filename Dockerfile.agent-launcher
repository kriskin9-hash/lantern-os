# See docker-compose.yml for which Dockerfile to use per service
# Agent Launcher - Runs agents inside container (no popups)
FROM python:3.11-slim

RUN groupadd -r appuser && useradd -r -g appuser appuser

WORKDIR /app

# Install minimal runtime deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy agent launcher and config
COPY services/agent-launcher/headless_launcher.py /app/launcher/
COPY config/agent-slots.json /app/config/
COPY requirements.txt /app/

# Install Python deps
RUN pip install --no-cache-dir -r requirements.txt

# Create directories
RUN mkdir -p /app/logs /app/state && chown -R appuser:appuser /app

USER appuser

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app

EXPOSE 5000-5010

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD curl -f http://localhost:5000/health || exit 1

CMD ["python", "/app/launcher/headless_launcher.py"]
