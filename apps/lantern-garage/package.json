{
  "name": "lantern-garage-app",
  "version": "1.4.0",
  "private": true,
  "description": "Local-first Lantern OS garage full-stack app.",
  "scripts": {
    "setup": "node ../../scripts/ensure-rust.js || true",
    "prestart": "npm run setup",
    "start": "node server.js",
    "start:dev": "node server-dev.js",
    "start:local": "node server.js",
    "start:sd": "python ../../src/sd_image_server.py",
    "check": "node --check server.js",
    "validate": "node validate.js",
    "test": "node ../../tests/run-dream-journal-tests.js api chat multiturn keystone cache",
    "test:api": "node ../../tests/test_dream_journal_api.js",
    "test:chat": "node ../../tests/test_dream_journal_chat.js",
    "test:multiturn": "node ../../tests/test_dream_chat_multiturns.js",
    "test:keystone": "node ../../tests/test_dream_journal_keystone.js",
    "test:cache": "node ../../tests/test_provider_cache.js",
    "test:ui": "npx playwright test ../../tests/test_dream_journal_ui.spec.js",
    "test:ui:headed": "npx playwright test ../../tests/test_dream_journal_ui.spec.js --headed",
    "test:three-doors": "node ../../tests/test_three_doors_integration.spec.js",
    "test:sprint16": "node ../../tests/test_sprint16_dashboards.js",
    "test:all": "node ../../tests/run-dream-journal-tests.js api chat multiturn keystone cache ui && npm run test:three-doors",
    "dev": "node --watch server.js",
    "start:master": "git -C ../.. pull origin master && python3 ../../integrations/human-flourishing-frameworks/export_snapshot.py || true && node --watch server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "busboy": "^1.6.0",
    "exif-parser": "^0.1.12",
    "express-session": "^1.19.0",
    "pdf-parse": "^1.1.1",
    "sharp": "^0.35.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "playwright": "^1.61.0"
  }
}
