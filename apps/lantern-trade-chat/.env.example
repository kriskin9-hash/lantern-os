# Lantern Trade Chat — environment template. Copy to .env (gitignored) and fill in.
# NEVER commit real values.

# --- Access control (GitHub OAuth) ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Comma-separated GitHub usernames allowed to sign in (founder + Courtney).
GITHUB_ALLOWED_LOGINS=alex-place
# Random 32+ byte string for signing session cookies (e.g. `openssl rand -hex 32`).
LANTERN_SESSION_SECRET=

# --- Kalshi credentials ---
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=
# demo (safe, simulated) or prod (real money).
KALSHI_ENVIRONMENT=demo

# --- Trading gates (safe defaults) ---
# Live trading stays OFF unless this is explicitly 1/true.
LANTERN_LIVE_ENABLED=0
LANTERN_MAX_PER_ORDER_USD=40
LANTERN_MAX_DAILY_LOSS_USD=40
LANTERN_MAX_TRADES_PER_DAY=1
