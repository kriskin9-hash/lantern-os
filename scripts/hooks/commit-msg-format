#!/bin/bash
# Commit-msg hook: Enforce structured commit messages with version info
# Install: cp scripts/hooks/commit-msg-format .git/hooks/commit-msg
#
# Commit message format:
#   type(scope): subject — description
#
#   Body (optional):
#   - Detailed explanation
#   - Multiple lines ok
#
# Types: feat, fix, docs, refactor, perf, test, chore, ci
# Scopes: (optional) training, versioning, api, ui, etc.
#
# Examples:
#   feat(training): add Bayesian LR scheduling — auto-adapts learning rate
#   fix(router): handle null intent classification
#   chore: bump version to v1.2.3
#   docs: update knowledge center with RAG house link

set -e

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip validation for merge commits
if echo "$COMMIT_MSG" | grep -q "^Merge "; then
    exit 0
fi

# Skip if message starts with interactive rebase commands
if echo "$COMMIT_MSG" | grep -q "^#"; then
    exit 0
fi

# Extract first line
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)

# Validate format: type(scope): subject or type: subject
TYPE_PATTERN="^(feat|fix|docs|refactor|perf|test|chore|ci|build|style|revert)"

if ! echo "$FIRST_LINE" | grep -qE "$TYPE_PATTERN"; then
    echo ""
    echo "[!] COMMIT MESSAGE VALIDATION FAILED"
    echo ""
    echo "First line must start with a type:"
    echo "  feat, fix, docs, refactor, perf, test, chore, ci, build, style, revert"
    echo ""
    echo "Format:"
    echo "  type(scope): subject — description"
    echo "  or"
    echo "  type: subject"
    echo ""
    echo "Examples:"
    echo "  feat(training): add Bayesian scheduling — auto-adapts learning rate"
    echo "  fix(router): handle null classification"
    echo "  chore: bump version to v1.2.3"
    echo "  docs: update knowledge center"
    echo ""
    echo "Current message:"
    echo "  $FIRST_LINE"
    echo ""
    exit 1
fi

# Validate that subject is not too short
SUBJECT=$(echo "$FIRST_LINE" | cut -d':' -f2- | xargs)
if [ ${#SUBJECT} -lt 8 ]; then
    echo ""
    echo "[!] COMMIT SUBJECT TOO SHORT (minimum 8 characters)"
    echo "    Current: '$SUBJECT' (${#SUBJECT} chars)"
    echo ""
    exit 1
fi

# Validate that subject is not too long
if [ ${#FIRST_LINE} -gt 100 ]; then
    echo ""
    echo "[!] COMMIT MESSAGE TOO LONG (maximum 100 characters per line)"
    echo "    Current: ${#FIRST_LINE} chars"
    echo "    Message: $FIRST_LINE"
    echo ""
    exit 1
fi

# Warn about missing body (optional)
LINE_COUNT=$(echo "$COMMIT_MSG" | wc -l)
if [ $LINE_COUNT -lt 3 ] && [ ${#SUBJECT} -lt 50 ]; then
    echo ""
    echo "[!] WARNING: Consider adding a commit body for context"
    echo "    Format: commit message + blank line + detailed explanation"
    echo ""
    # Don't exit; this is just a warning
fi

exit 0
