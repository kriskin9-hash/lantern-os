#!/bin/bash
# Comprehensive pre-commit hook: Version, Deployment, Auto-update, and Agent validation
# Combines:
#   1. Version/changelog validation
#   2. Deployment readiness validation
#   3. Auto-update safety validation
#   4. AGENTS.md documentation validation
#
# Skip with environment variables:
#   SKIP_VERSION_CHECK=1      - skip version/changelog
#   SKIP_DEPLOY_CHECK=1       - skip deployment validation
#   SKIP_UPDATE_CHECK=1       - skip auto-update safety
#   SKIP_AGENT_CHECK=1        - skip AGENTS.md validation
#
# Skip all validations (emergency only):
#   SKIP_ALL_CHECKS=1 git commit

set -e

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." && pwd )"

echo "[*] Running pre-commit validations..."
echo ""

FAILED=0

# Skip all (emergency)
if [ -n "$SKIP_ALL_CHECKS" ]; then
    echo "[!] All validations skipped (SKIP_ALL_CHECKS set)"
    exit 0
fi

# 1. Version/Changelog validation
if [ -z "$SKIP_VERSION_CHECK" ]; then
    echo "[*] 1/4: Version & Changelog validation..."
    if python3 "$SCRIPT_DIR/validate-version-changelog.py"; then
        echo "[✓] Version/Changelog: PASS"
    else
        echo "[✗] Version/Changelog: FAIL"
        FAILED=1
    fi
    echo ""
else
    echo "[!] Version validation skipped (SKIP_VERSION_CHECK set)"
    echo ""
fi

# 2. Deployment readiness validation
if [ -z "$SKIP_DEPLOY_CHECK" ]; then
    echo "[*] 2/4: Deployment readiness validation..."
    if python3 "$SCRIPT_DIR/validate-deployment-readiness.py"; then
        echo "[✓] Deployment: PASS"
    else
        echo "[✗] Deployment: FAIL"
        FAILED=1
    fi
    echo ""
else
    echo "[!] Deployment validation skipped (SKIP_DEPLOY_CHECK set)"
    echo ""
fi

# 3. Auto-update safety validation
if [ -z "$SKIP_UPDATE_CHECK" ]; then
    echo "[*] 3/4: Auto-update safety validation..."
    if python3 "$SCRIPT_DIR/validate-autoupdate-safety.py"; then
        echo "[✓] Auto-update: PASS"
    else
        echo "[✗] Auto-update: FAIL"
        FAILED=1
    fi
    echo ""
else
    echo "[!] Auto-update validation skipped (SKIP_UPDATE_CHECK set)"
    echo ""
fi

# 4. AGENTS.md validation
if [ -z "$SKIP_AGENT_CHECK" ]; then
    echo "[*] 4/4: AGENTS.md validation..."
    if python3 "$SCRIPT_DIR/validate-agents-md.py"; then
        echo "[✓] AGENTS.md: PASS"
    else
        echo "[✗] AGENTS.md: FAIL"
        FAILED=1
    fi
    echo ""
else
    echo "[!] AGENTS.md validation skipped (SKIP_AGENT_CHECK set)"
    echo ""
fi

# Summary
echo "=========================================="
if [ $FAILED -eq 0 ]; then
    echo "[OK] All validations passed"
    exit 0
else
    echo "[!] VALIDATION FAILED"
    echo ""
    echo "Fix the issues above and try again."
    echo ""
    echo "To skip individual checks:"
    echo "  SKIP_VERSION_CHECK=1 git commit"
    echo "  SKIP_DEPLOY_CHECK=1 git commit"
    echo "  SKIP_UPDATE_CHECK=1 git commit"
    echo "  SKIP_AGENT_CHECK=1 git commit"
    echo ""
    echo "Emergency (all checks):"
    echo "  SKIP_ALL_CHECKS=1 git commit"
    exit 1
fi
