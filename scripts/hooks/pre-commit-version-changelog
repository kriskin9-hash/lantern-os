#!/bin/bash
# Pre-commit hook: Enforce version bump and changelog entry consistency
# Install: cp scripts/hooks/pre-commit-version-changelog .git/hooks/pre-commit
# Skip:    SKIP_VERSION_CHECK=1 git commit

set -e

# Allow skipping this check
if [ -n "$SKIP_VERSION_CHECK" ]; then
    echo "[*] Skipping version/changelog validation (SKIP_VERSION_CHECK set)"
    exit 0
fi

# Run validation
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." && pwd )"
python3 "$SCRIPT_DIR/validate-version-changelog.py"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "[!] To bypass: SKIP_VERSION_CHECK=1 git commit"
    echo "[!] Or fix the issues above and stage the changes"
    exit 1
fi

exit 0
