#!/bin/sh
# Per-agent workstream gate (pre-commit)
#
# Rules:
#   1. Each agent prefix (claude/, gemini/, codex/, devin/, grok/, openai/) gets
#      exactly ONE open PR lane. A second branch from the same agent is blocked
#      until the first PR is merged or closed.
#   2. "Human" branches (no recognised agent prefix) share one lane between them.
#   3. Commits TO a branch that already has an open PR are always allowed.
#   4. gh-pages, master, dev are exempt.
#
# Bypass: SKIP_MONOWORKSTREAM=1 git commit ...

# ── Primary-checkout master guard (runs before all bypasses) ────────────────
# A long-running automation must NEVER commit the SHARED git index of the live
# (primary) checkout: the index is shared, so a commit here sweeps up whatever
# another worker (a human, another agent) has staged or left modified — the
# "clobber" bug. Require master/main commits to come from an isolated linked
# worktree, where the index is private.
# Deliberate bypass ONLY: OVERRIDE_MERGE=1 (intentionally NOT honouring
# SKIP_MONOWORKSTREAM here, so routine automation that sets it can't slip past).
__guard_branch=$(git symbolic-ref --short HEAD 2>/dev/null)
case "$__guard_branch" in
  master|main)
    if [ "$OVERRIDE_MERGE" != "1" ]; then
      __gd=$(git rev-parse --git-dir 2>/dev/null)
      __cd=$(git rev-parse --git-common-dir 2>/dev/null)
      if [ "$__gd" = "$__cd" ]; then
        echo ""
        echo "PRIMARY-CHECKOUT MASTER GUARD: refusing to commit to '$__guard_branch' from the primary checkout."
        echo "  The primary working tree's git index is SHARED — committing here can sweep up"
        echo "  another worker's staged/working changes (the clobber bug)."
        echo "  Fix: commit from an isolated linked worktree (git worktree add ...)."
        echo "  Deliberate override: OVERRIDE_MERGE=1 git commit ..."
        echo ""
        exit 1
      fi
    fi
    ;;
esac

if [ "$SKIP_MONOWORKSTREAM" = "1" ]; then exit 0; fi
if ! command -v gh >/dev/null 2>&1; then
  echo "Warning: gh CLI not found — per-agent workstream gate skipped."
  exit 0
fi

branch=$(git symbolic-ref --short HEAD 2>/dev/null)
[ -z "$branch" ] && exit 0
case "$branch" in gh-pages|master|dev) exit 0 ;; esac

# Derive agent prefix
agent=$(echo "$branch" | cut -d'/' -f1)
case "$agent" in
  claude|gemini|codex|devin|grok|openai) ;;
  *) agent="human" ;;
esac

# Allow if this branch already has an open PR (fixing an existing PR)
branch_pr=$(gh pr list --repo alex-place/lantern-os --state open \
  --json headRefName \
  --jq "map(select(.headRefName == \"$branch\")) | length" 2>/dev/null)
[ "${branch_pr:-0}" -gt 0 ] && exit 0

# Check for a conflicting open PR from the same agent lane
if [ "$agent" = "human" ]; then
  conflict=$(gh pr list --repo alex-place/lantern-os --state open \
    --json headRefName \
    --jq '[.[] | select(.headRefName | test("^(claude|gemini|codex|devin|grok|openai)/") | not)] | length' \
    2>/dev/null)
else
  conflict=$(gh pr list --repo alex-place/lantern-os --state open \
    --json headRefName \
    --jq "[.[] | select(.headRefName | startswith(\"$agent/\"))] | length" \
    2>/dev/null)
fi

if [ "${conflict:-0}" -gt 0 ]; then
  echo ""
  echo "PER-AGENT WORKSTREAM BLOCK: agent '$agent' already has an open PR."
  echo ""
  if [ "$agent" = "human" ]; then
    gh pr list --repo alex-place/lantern-os --state open \
      --json number,title,headRefName \
      --jq '[.[] | select(.headRefName | test("^(claude|gemini|codex|devin|grok|openai)/") | not)] | .[] | "  #\(.number) \(.title) [\(.headRefName)]"' \
      2>/dev/null
  else
    gh pr list --repo alex-place/lantern-os --state open \
      --json number,title,headRefName \
      --jq "[.[] | select(.headRefName | startswith(\"$agent/\"))] | .[] | \"  #\\(.number) \\(.title) [\\(.headRefName)]\"" \
      2>/dev/null
  fi
  echo ""
  echo "Finish or close that PR before opening another lane for '$agent'."
  echo "Bypass: SKIP_MONOWORKSTREAM=1 git commit ..."
  echo ""
  exit 1
fi

# ── Slop scan: inspect staged code files ────────────────────────────────────
slop_fail=0

for file in $(git diff --cached --name-only); do
  # Only scan source files
  case "$file" in
    *.js|*.ts|*.py|*.sh|*.mjs|*.cjs) ;;
    *) continue ;;
  esac

  # Read staged content (not working tree)
  content=$(git show ":$file" 2>/dev/null) || continue

  # 1. Hardcoded secrets — pattern: assignment to a key/secret/token/password var
  if echo "$content" | grep -iqE \
    "(api_key|apikey|api_secret|secret_key|password|passwd|access_token|auth_token|private_key)\s*[=:]\s*['\"][a-zA-Z0-9/+_\-]{12,}['\"]"; then
    echo "SLOP [secret]: possible hardcoded credential in $file"
    echo "  Use environment variables or .env — never commit secrets."
    slop_fail=1
  fi

  # 2. Debug pollution
  if echo "$content" | grep -qE \
    "(^|[^a-zA-Z])(console\.log\(|debugger;|pdb\.set_trace\(\)|breakpoint\(\)|import pdb)"; then
    echo "SLOP [debug]: debug statement found in $file — remove before committing."
    slop_fail=1
  fi

  # 3. SQL injection risk — string-concatenated query
  if echo "$content" | grep -iqE \
    "(SELECT|INSERT|UPDATE|DELETE).*\+\s*(req\.|params\.|query\.|body\.|args\.)"; then
    echo "SLOP [sqli]: possible SQL string concatenation with user input in $file"
    slop_fail=1
  fi

  # 4. eval() / shell injection
  if echo "$content" | grep -qE \
    "(^|[^a-zA-Z])(eval\(|exec\(|os\.system\(|subprocess\.call\([^,]*shell\s*=\s*True)"; then
    echo "SLOP [exec]: unsafe eval/exec/shell call in $file — use safe alternatives."
    slop_fail=1
  fi
done

# 5. Oversized commit — count SOURCE lines only (docs / data / configs exempt).
#    Convergence work is documentation- and experiment-output-heavy; gating on the
#    total line count false-blocks legitimate research commits. Mirror the CI gate
#    in .github/workflows/slop-check.yml (source-only, limit 1000) so local == CI.
added=$(git diff --cached --numstat -- '*.js' '*.ts' '*.py' '*.sh' '*.mjs' '*.cjs' \
  | awk '{sum += $1} END {print sum+0}')
if [ "$added" -gt 1000 ]; then
  echo "SLOP [size]: $added source lines added in one commit (limit 1000) — split into atomic changes."
  slop_fail=1
fi

if [ "$slop_fail" -gt 0 ]; then
  echo ""
  echo "Fix the issues above or bypass with: SKIP_MONOWORKSTREAM=1 git commit ..."
  echo ""
  exit 1
fi

exit 0
