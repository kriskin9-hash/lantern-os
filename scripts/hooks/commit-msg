#!/bin/sh
# Slop detector (commit-msg hook)
#
# Blocks commits whose message signals low-quality / placeholder work.
# Bypass: SKIP_MONOWORKSTREAM=1 git commit ...

if [ "$SKIP_MONOWORKSTREAM" = "1" ]; then exit 0; fi

msg_file="$1"
msg=$(cat "$msg_file" | sed '/^#/d' | sed '/^$/d' | head -1 | tr '[:upper:]' '[:lower:]' | xargs)

# Empty after stripping comments
if [ -z "$msg" ]; then
  echo ""
  echo "SLOP BLOCK: commit message is empty."
  echo ""
  exit 1
fi

# Too short (< 8 meaningful chars)
if [ ${#msg} -lt 8 ]; then
  echo ""
  echo "SLOP BLOCK: commit message too short (\"$msg\"). Describe what changed and why."
  echo ""
  exit 1
fi

# Pure noise words
case "$msg" in
  wip|"wip."|fix|fixes|update|updates|changes|stuff|test|testing|temp|tmp|draft|misc|done|ok|checkpoint)
    echo ""
    echo "SLOP BLOCK: \"$(cat "$msg_file" | head -1)\" is not a useful commit message."
    echo "Use: type(scope): what changed and why"
    echo ""
    exit 1
    ;;
esac

# Slop phrases anywhere in message
for pattern in "placeholder" "todo: " "fixme:" "do not merge" "remove before" "DELETE ME" "TEMP:"; do
  lower_pattern=$(echo "$pattern" | tr '[:upper:]' '[:lower:]')
  if echo "$msg" | grep -qi "$lower_pattern"; then
    echo ""
    echo "SLOP BLOCK: message contains \"$pattern\" — clean it up before committing."
    echo ""
    exit 1
  fi
done

exit 0
