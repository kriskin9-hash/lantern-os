#!/bin/sh
# Per-agent workstream gate + master protection + change-record gate (pre-push)
#
# Master merge override:     OVERRIDE_MERGE=1 git push origin master
# Workstream bypass:         SKIP_MONOWORKSTREAM=1 git push ...
# Change-record/bump bypass: SKIP_VERSION_CHECK=1 git push ...

# ── 1. Master protection ─────────────────────────────────────────────────────
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/master" ]; then
    if [ "$OVERRIDE_MERGE" = "1" ]; then
      echo "[merge] OVERRIDE_MERGE=1 — allowing direct push to master."
    else
      echo ""
      echo "MASTER PROTECTION: direct push to master is blocked."
      echo "Open a pull request, or set OVERRIDE_MERGE=1 to force."
      echo ""
      exit 1
    fi
  fi
done

# ── 2. Change-record + version-bump gate ─────────────────────────────────────
# A code-bearing branch must bump package.json to a new X.X.X version AND carry a
# matching CHANGELOG.MD entry, relative to origin/master. Runs BEFORE the gh /
# workstream checks below so it is enforced even without gh and even on branches
# that already have an open PR.
# Bypass: SKIP_VERSION_CHECK=1 (or SKIP_MONOWORKSTREAM=1) git push ...
if [ "$SKIP_MONOWORKSTREAM" != "1" ] && [ "$SKIP_VERSION_CHECK" != "1" ]; then
  _root=$(git rev-parse --show-toplevel 2>/dev/null)
  _validator="$_root/scripts/validate-prepush-version-changelog.py"
  if [ -f "$_validator" ]; then
    _py=$(command -v python3 2>/dev/null || command -v python 2>/dev/null)
    if [ -n "$_py" ]; then
      if ! "$_py" "$_validator"; then
        exit 1
      fi
    else
      echo "[prepush] python not found on PATH — skipping change-record gate."
    fi
  fi
fi

# ── 3. Per-agent workstream gate ─────────────────────────────────────────────
if [ "$SKIP_MONOWORKSTREAM" = "1" ]; then exit 0; fi
if ! command -v gh >/dev/null 2>&1; then exit 0; fi

# Re-read refs (stdin was consumed above; get branch from git)
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
[ -z "$branch" ] && exit 0
case "$branch" in gh-pages|master|dev) exit 0 ;; esac

agent=$(echo "$branch" | cut -d'/' -f1)
case "$agent" in
  claude|gemini|codex|devin|grok|openai) ;;
  *) agent="human" ;;
esac

# Allow push if this branch already has an open PR
branch_pr=$(gh pr list --repo alex-place/lantern-os --state open \
  --json headRefName \
  --jq "map(select(.headRefName == \"$branch\")) | length" 2>/dev/null)
[ "${branch_pr:-0}" -gt 0 ] && exit 0

# Check for conflicting open PR in same agent lane
if [ "$agent" = "human" ]; then
  conflict=$(gh pr list --repo alex-place/lantern-os --state open \
    --json headRefName \
    --jq '[.[] | select(.headRefName | test("^(claude|gemini|codex|devin|grok|openai)/") | not)] | length' \
    2>/dev/null)
else
  conflict=$(gh pr list --repo alex-place/lantern-os --state open \
    --json headRefName \
    --jq "[.[] | select(.headRefName | startswith(\"$agent/\"))] | length" \
    2>/dev/null)
fi

if [ "${conflict:-0}" -gt 0 ]; then
  echo ""
  echo "PER-AGENT WORKSTREAM BLOCK: agent '$agent' already has an open PR."
  if [ "$agent" = "human" ]; then
    gh pr list --repo alex-place/lantern-os --state open \
      --json number,title,headRefName \
      --jq '[.[] | select(.headRefName | test("^(claude|gemini|codex|devin|grok|openai)/") | not)] | .[] | "  #\(.number) \(.title) [\(.headRefName)]"' \
      2>/dev/null
  else
    gh pr list --repo alex-place/lantern-os --state open \
      --json number,title,headRefName \
      --jq "[.[] | select(.headRefName | startswith(\"$agent/\"))] | .[] | \"  #\\(.number) \\(.title) [\\(.headRefName)]\"" \
      2>/dev/null
  fi
  echo ""
  echo "Bypass: SKIP_MONOWORKSTREAM=1 git push ..."
  echo ""
  exit 1
fi

# ── 4. Staleness guard: block pushes on branches far behind master ────────────
_branch=$(git symbolic-ref --short HEAD 2>/dev/null)
case "$_branch" in gh-pages|master|dev|"") ;;
*)
  _behind=$(git rev-list --count HEAD..origin/master 2>/dev/null || echo 0)
  if [ "$_behind" -gt 50 ]; then
    echo ""
    echo "STALENESS BLOCK: '$_branch' is $_behind commits behind origin/master."
    echo "Pushing now risks large merge conflicts and dropped work."
    echo ""
    echo "Sync first:"
    echo "  git fetch origin"
    echo "  git rebase origin/master   # or: git merge origin/master"
    echo ""
    echo "Bypass: SKIP_MONOWORKSTREAM=1 git push ..."
    echo ""
    exit 1
  elif [ "$_behind" -gt 10 ]; then
    echo ""
    echo "WARNING: '$_branch' is $_behind commits behind origin/master."
    echo "Consider syncing: git fetch origin && git rebase origin/master"
    echo ""
  fi
  ;;
esac

# ── 5. Git LFS ───────────────────────────────────────────────────────────────
command -v git-lfs >/dev/null 2>&1 || {
  echo "Warning: git-lfs not found on PATH. LFS pre-push hook skipped."
  exit 0
}
git lfs pre-push "$@"
