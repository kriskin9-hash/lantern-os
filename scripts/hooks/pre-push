#!/bin/sh
# Per-agent workstream gate + master protection (pre-push)
#
# Master merge override: OVERRIDE_MERGE=1 git push origin master
# Workstream bypass:     SKIP_MONOWORKSTREAM=1 git push ...

# ── 1. Master protection ─────────────────────────────────────────────────────
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/master" ]; then
    if [ "$OVERRIDE_MERGE" = "1" ]; then
      echo "[merge] OVERRIDE_MERGE=1 — allowing direct push to master."
    else
      echo ""
      echo "MASTER PROTECTION: direct push to master is blocked."
      echo "Open a pull request, or set OVERRIDE_MERGE=1 to force."
      echo ""
      exit 1
    fi
  fi
done

# ── 2. Per-agent workstream gate ─────────────────────────────────────────────
if [ "$SKIP_MONOWORKSTREAM" = "1" ]; then exit 0; fi
if ! command -v gh >/dev/null 2>&1; then exit 0; fi

# Re-read refs (stdin was consumed above; get branch from git)
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
[ -z "$branch" ] && exit 0
case "$branch" in gh-pages|master|dev) exit 0 ;; esac

agent=$(echo "$branch" | cut -d'/' -f1)
case "$agent" in
  claude|gemini|codex|devin|grok|openai) ;;
  *) agent="human" ;;
esac

# Allow push if this branch already has an open PR
branch_pr=$(gh pr list --repo alex-place/lantern-os --state open \
  --json headRefName \
  --jq "map(select(.headRefName == \"$branch\")) | length" 2>/dev/null)
[ "${branch_pr:-0}" -gt 0 ] && exit 0

# Check for conflicting open PR in same agent lane
if [ "$agent" = "human" ]; then
  conflict=$(gh pr list --repo alex-place/lantern-os --state open \
    --json headRefName \
    --jq '[.[] | select(.headRefName | test("^(claude|gemini|codex|devin|grok|openai)/") | not)] | length' \
    2>/dev/null)
else
  conflict=$(gh pr list --repo alex-place/lantern-os --state open \
    --json headRefName \
    --jq "[.[] | select(.headRefName | startswith(\"$agent/\"))] | length" \
    2>/dev/null)
fi

if [ "${conflict:-0}" -gt 0 ]; then
  echo ""
  echo "PER-AGENT WORKSTREAM BLOCK: agent '$agent' already has an open PR."
  if [ "$agent" = "human" ]; then
    gh pr list --repo alex-place/lantern-os --state open \
      --json number,title,headRefName \
      --jq '[.[] | select(.headRefName | test("^(claude|gemini|codex|devin|grok|openai)/") | not)] | .[] | "  #\(.number) \(.title) [\(.headRefName)]"' \
      2>/dev/null
  else
    gh pr list --repo alex-place/lantern-os --state open \
      --json number,title,headRefName \
      --jq "[.[] | select(.headRefName | startswith(\"$agent/\"))] | .[] | \"  #\\(.number) \\(.title) [\\(.headRefName)]\"" \
      2>/dev/null
  fi
  echo ""
  echo "Bypass: SKIP_MONOWORKSTREAM=1 git push ..."
  echo ""
  exit 1
fi

# ── 3. Git LFS ───────────────────────────────────────────────────────────────
command -v git-lfs >/dev/null 2>&1 || {
  echo "Warning: git-lfs not found on PATH. LFS pre-push hook skipped."
  exit 0
}
git lfs pre-push "$@"
