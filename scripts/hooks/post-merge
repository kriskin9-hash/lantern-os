#!/bin/sh
# post-merge: surface stale branches after a merge into master/dev
# Runs automatically after every `git merge` or `git pull`.

current=$(git symbolic-ref --short HEAD 2>/dev/null)
case "$current" in master|dev) ;; *) exit 0 ;; esac

stale=""
while IFS= read -r _b; do
  _b=$(echo "$_b" | sed 's/^\* //' | xargs)
  case "$_b" in master|dev|gh-pages|HEAD|"") continue ;; esac
  _behind=$(git rev-list --count "$_b"..HEAD 2>/dev/null || echo 0)
  if [ "$_behind" -gt 10 ]; then
    stale="${stale}  ${_b}  (${_behind} behind)\n"
  fi
done < <(git branch)

if [ -n "$stale" ]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "STALE BRANCHES — sync to avoid future conflicts"
  printf "%b" "$stale"
  echo ""
  echo "For each branch: git checkout <branch> && git rebase master"
  echo "Or delete stale: git branch -D <branch>"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
fi

exit 0
