# Lantern OS Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real secrets to version control

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Main server port (default: 4177)
LANTERN_GARAGE_PORT=4177

# Server bind address (127.0.0.1 for local only, 0.0.0.0 for all interfaces)
LANTERN_GARAGE_HOST=127.0.0.1

# ============================================================================
# AI PROVIDER CREDENTIALS (at least 1 required for Dream Chat)
# ============================================================================

# Anthropic Claude API
# Get key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-v0-...
# ANTHROPIC_MODEL=claude-opus-4-8|claude-sonnet-4-6|claude-haiku-4-5-20251001 (default: haiku)

# OpenAI ChatGPT API
# Get key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Google Gemini API
# Get key from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIzaSy...
# GEMINI_GROUNDING=true

# ============================================================================
# LOCAL AI (Ollama) - Optional
# Install from: https://ollama.ai
# ============================================================================

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=lantern-csf-dream
OLLAMA_TIMEOUT_MS=120000

# ============================================================================
# MCP SERVER (for context://personas resource)
# ============================================================================

MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8771
MCP_CLIENT_TIMEOUT=5000

# MCP public access (set MCP_PUBLIC=1 to bind 0.0.0.0 when running behind Cloudflare tunnel)
# MCP_PUBLIC=1

# Static API key for Grok / Claude Desktop Bearer auth (leave blank = open/no auth)
# MCP_API_KEY=your-secret-key-here

# OAuth base URL for ChatGPT connector (must match the public hostname)
MCP_BASE_URL=https://mcp.lantern-os.net

# OAuth client ID advertised to ChatGPT (must match what you enter in ChatGPT connector UI)
MCP_OAUTH_CLIENT_ID=chatgpt

# ============================================================================
# IMAGE GENERATION (Optional)
# ============================================================================

SD_HOST=127.0.0.1
SD_PORT=7860

# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=Rachel

# ============================================================================
# PATREON OAUTH (Optional — enables Patreon login + role-gating)
# ============================================================================

# Register OAuth app: https://www.patreon.com/settings/developers
# PATREON_CLIENT_ID=...
# PATREON_CLIENT_SECRET=... (NEVER commit this!)
# PATREON_REDIRECT_URI=https://your-domain.com/api/auth/patreon/callback
# PATREON_CAMPAIGN_ID=... (get from https://www.patreon.com/api/oauth2/v2/campaigns)
# SESSION_SECRET=... (random string for signing sessions, change in production)

# Tier ID to Role mapping (get tier IDs from /api/oauth2/v2/campaigns/{id}/tiers):
# PATREON_TIER_SUPPORTER=123456
# PATREON_TIER_FOUNDER=234567
# PATREON_TIER_ADMIN=345678

# ============================================================================
# DISCORD BOT (Optional)
# ============================================================================

# DISCORD_BOT_TOKEN=...
# LANTERN_DISCORD_GUILD_ID=...

# ============================================================================
# ADVANCED FEATURES (Optional)
# ============================================================================

# LANTERN_IMAGE_LORA=models/csf-image/checkpoints/lantern-door-lora-final.safetensors
# LANTERN_CLOUD_MIRROR_URLS=...
# HFF_REPO_PATH=...
# THREE_DOORS_IMAGE_POOL_DIR=...

# ============================================================================
# TRADING / FINANCIAL SERVICES (Optional)
# ============================================================================

# AI_TRADER_HOST=127.0.0.1
# AI_TRADER_PORT=5555
# ALPACA_API_KEY=...
# OPENAI_API_KEY=... (if using trading features)

# === MCP Server ===
MCP_SERVER_PORT=8771
MCP_SERVER_HOST=127.0.0.1

# === MCP OAuth Server (external client auth, ChatGPT plugin connector) ===
MCP_OAUTH_PORT=8772
MCP_OAUTH_JWT_SECRET=change-me-before-production

# === MCP Public Tunnel (for ChatGPT connector and external clients) ===
# Set to the public HTTPS tunnel URL (e.g., https://mcp.lantern-os.net)
MCP_PUBLIC_BASE_URL=http://127.0.0.1:8772

# === RAG / External Repos ===
HFF_REPO_PATH=
CHILD_OF_LEVISTUS_PATH=

# === Generic HTTP port (used by some services) ===
PORT=

# === Three Doors Image Pool ===
# Local CAAD image pool directory. Falls back to data/images/caadi/ if unset.
THREE_DOORS_IMAGE_POOL_DIR=

# ============================================================================
# NOTES
# ============================================================================
#
# 1. MINIMUM for Dream Chat: Set at least ONE AI provider
#    (ANTHROPIC_API_KEY, OPENAI_API_KEY, GEMINI_API_KEY, or Ollama)
#
# 2. Provider Failover (automatic):
#    Ollama → Anthropic → Gemini → OpenAI → Offline fallback
#
# 3. Start: npm start
#    Access: http://127.0.0.1:4177/dream-chat.html
#
# 4. Never commit .env with real API keys!
