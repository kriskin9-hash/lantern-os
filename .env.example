# TRADING / FINANCIAL SERVICES (Optional)
# ============================================================================

# AI_TRADER_HOST=127.0.0.1
# AI_TRADER_PORT=5555
# ALPACA_API_KEY=...
# OPENAI_API_KEY=... (if using trading features)

# === MCP Server ===
MCP_SERVER_PORT=8771
MCP_SERVER_HOST=127.0.0.1

# === MCP OAuth Server (external client auth, ChatGPT plugin connector) ===
MCP_OAUTH_PORT=8772
MCP_OAUTH_JWT_SECRET=change-me-before-production

# === MCP Public Tunnel (for ChatGPT connector and external clients) ===
# Set to the public HTTPS tunnel URL (e.g., https://mcp.lantern-os.net)
MCP_PUBLIC_BASE_URL=http://127.0.0.1:8772

# === RAG / External Repos ===
HFF_REPO_PATH=
CHILD_OF_LEVISTUS_PATH=

# === Generic HTTP port (used by some services) ===
PORT=

# === Three Doors Image Pool ===
# Local CAAD image pool directory. Falls back to data/images/caadi/ if unset.
THREE_DOORS_IMAGE_POOL_DIR=

# === Cloud GPU Training Orchestrator ===
# Kaggle (primary — 30 h/wk free, automatable via REST kernel push)
# Get from: https://www.kaggle.com/settings/account → API Tokens
KAGGLE_API_TOKEN=
# Legacy fallback (download kaggle.json from Settings → Legacy API Credentials)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Lightning AI Studios (22 credits/month after phone verify, automatable)
# Get from: lightning.ai → Account Settings → Keys → Programmatic Login
LIGHTNING_USER_ID=
LIGHTNING_API_KEY=
LIGHTNING_STUDIO_USER=alexplace7
LIGHTNING_STUDIO_TEAMSPACE=custom-ml-model-development-project
LIGHTNING_STUDIO_NAME=ouro-training

# Paperspace Gradient (8 GB VRAM, requires PRO subscription ~$8/mo)
# Get from: https://console.paperspace.com/account/api
PAPERSPACE_API_KEY=

# ============================================================================
# NOTES
# ============================================================================
#
# 1. MINIMUM for Dream Chat: Set at least ONE AI provider
#    (ANTHROPIC_API_KEY, OPENAI_API_KEY, GEMINI_API_KEY, or Ollama)
#
# 2. Provider Failover (automatic):
#    Ollama → Anthropic → Gemini → OpenAI → Offline fallback
#
# 3. Start: npm start
#    Access: http://127.0.0.1:4177/dream-chat.html
#
# 4. Never commit .env with real API keys!

# ============================================================================
# BRAND LOGOS (optional — stock-trader watchlist/search badges)
# ============================================================================
# logo.dev gives crisp, icon-style, high-res brand logos (better than the FMP
# fallback). Get a free publishable token at https://logo.dev (looks like pk_...).
# Without this the trader falls back to FMP logos automatically.
# LOCAL:  add the line below to .env.local (gitignored — never commit the token).
# CLOUD (Railway): do NOT put it in the repo. Set LOGODEV_TOKEN in the Railway
#   service's Variables tab so the deployed site reads it from the environment.
# LOGODEV_TOKEN=pk_xxxxxxxxxxxxxxxxxxxx

# ============================================================================
# TRADER — API-spend controls (Σ₀ scan cache + adaptive cadence)
# ============================================================================
# Σ₀ scan cache: reuse a ticker's LLM read when its price is essentially
# unchanged since the last scan, so the model is only paid for when price moves.
# Grounding signals are still recomputed fresh, so it can't miss a setup.
# SIGMA0_SCAN_CACHE=1            # 0 to disable
# SIGMA0_SCAN_CACHE_BAND=0.0015  # price move (0.15%) that counts as "changed"
# SIGMA0_SCAN_CACHE_TTL=600      # re-read at least every N seconds
# Adaptive cadence: scan slower when the US market is closed (crypto-only, slow).
# TRADER_AUTOSCAN_MS=60000          # market-hours cadence
# TRADER_AUTOSCAN_CLOSED_MS=300000  # off-hours cadence (set =60000 to disable)
# Σ₀ grounding pre-gate: only spend the model on tickers that could actually ENTER
# (near a zone, or a real trend/news lean). Flat/featureless tickers would SKIP
# regardless, so they're dropped pre-LLM. Conservative + fail-open; held positions
# always pass. Provably can't drop a setup the full flow would take.
# SIGMA0_PREGATE=1               # 0 to disable
# SIGMA0_PREGATE_ZONE_PROX=3.5   # % distance to a zone that still counts as a candidate
