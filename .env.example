# Lantern OS Environment Variables
# Copy this file to .env and fill in your keys

# === Discord Bot ===
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# === LLM Providers (Real providers only for V1) ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash

# Optional / Future
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# === Dream Journal ===
DREAM_JOURNAL_PORT=4177

# === Lantern Garage Server ===
LANTERN_GARAGE_PORT=4177
LANTERN_GARAGE_HOST=127.0.0.1
LANTERN_CLOUD_MIRROR_URLS=
LANTERN_REPO_ROOT=

# === Review Door ===
LANTERN_REVIEW_DOOR_PORT=4181
LANTERN_REVIEW_DOOR_HOST=127.0.0.1

# === Stripe / Payment Bridge ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MODE=test
PAYMENT_BRIDGE_PORT=4182

# === Dream Agent ===
DREAM_AGENT_MODEL=llama3.2
DREAM_AGENT_ENABLE_OPENAI=false

# === MCP OAuth Server ===
MCP_OAUTH_JWT_SECRET=change_me_to_a_random_secret
MCP_OAUTH_ISSUER=lantern-os-mcp-oauth
MCP_OAUTH_TOKEN_TTL=60
MCP_OAUTH_HOST=127.0.0.1
MCP_OAUTH_PORT=8772

# === MCP Server ===
MCP_SERVER_PORT=8771
MCP_SERVER_HOST=127.0.0.1

# === RAG / External Repos ===
HFF_REPO_PATH=
CHILD_OF_LEVISTUS_PATH=

# === Generic HTTP port (used by some services) ===
PORT=
