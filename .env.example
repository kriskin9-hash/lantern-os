# Lantern OS Environment Variables
# Copy this file to .env and fill in your keys

# === Discord Bot ===
# Get token from https://discord.com/developers/applications → your app → Bot → Reset Token
# Get guild ID: Discord → server icon right-click → Copy Server ID (Developer Mode must be on)
# Bot invite URL: https://discord.com/api/oauth2/authorize?client_id=YOUR_CLIENT_ID&permissions=93264&scope=bot%20applications.commands
DISCORD_BOT_TOKEN=your_discord_bot_token_here
LANTERN_DISCORD_GUILD_ID=your_server_id_here

# === LLM Providers (Real providers only for V1) ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash

# Optional / Future
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# === Convergance OS Local Models ===
DREAMCHAT_MODEL=lantern-csf-dream
PCSF_MODEL=lantern-pcsf
CONVERGENCE_MODEL=lantern-convergance
LANTERN_IMAGE_LORA=models/csf-image/checkpoints/lantern-door-lora-final.safetensors

# === Dream Journal ===
DREAM_JOURNAL_PORT=4177

# === Stable Diffusion Image Server (In-house) ===
SD_HOST=127.0.0.1
SD_PORT=7860
SD_MODEL_PATH=models/csf-image/merged

# === Lantern Garage Server ===
LANTERN_GARAGE_PORT=4177
LANTERN_GARAGE_HOST=127.0.0.1
LANTERN_CLOUD_MIRROR_URLS=
LANTERN_REPO_ROOT=

# === Review Door ===
LANTERN_REVIEW_DOOR_PORT=4181
LANTERN_REVIEW_DOOR_HOST=127.0.0.1

# === Trading APIs ===
# Alpaca paper trading — https://app.alpaca.markets → Home → API Keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Kalshi prediction markets — https://kalshi.com/account/api
KALSHI_API_KEY=
# IBKR Gateway host/port (default: localhost:4001 when TWS/Gateway is running)
IBKR_HOST=localhost
IBKR_PORT=4001

# === Stripe / Payment Bridge ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MODE=test
PAYMENT_BRIDGE_PORT=4182

# === Dream Agent ===
DREAM_AGENT_MODEL=llama3.2
DREAM_AGENT_ENABLE_OPENAI=false

# === MCP OAuth Server ===
MCP_OAUTH_JWT_SECRET=change_me_to_a_random_secret
MCP_OAUTH_ISSUER=lantern-os-mcp-oauth
MCP_OAUTH_TOKEN_TTL=60
MCP_OAUTH_HOST=127.0.0.1
MCP_OAUTH_PORT=8772

# === MCP Server ===
MCP_SERVER_PORT=8771
MCP_SERVER_HOST=127.0.0.1

# === RAG / External Repos ===
HFF_REPO_PATH=
CHILD_OF_LEVISTUS_PATH=

# === Generic HTTP port (used by some services) ===
PORT=
