# ── Lantern OS Environment ──

# Discord Bot
DISCORD_BOT_TOKEN=your-bot-token-here
LANTERN_DISCORD_GUILD_ID=your-guild-id-here
LANTERN_DISCORD_CHANNEL_ID=your-channel-id-here

# MCP Server
MCP_SERVER_URL=http://127.0.0.1:8771
MCP_SERVER_PORT=8771
MCP_SERVER_HOST=127.0.0.1

# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Database (optional)
DATABASE_URL=postgresql://user:pass@localhost/lantern_os
REDIS_URL=redis://localhost:6379/0

# Feature flags
DEBUG=true
ENABLE_MCP=true
ENABLE_VOICE=true
