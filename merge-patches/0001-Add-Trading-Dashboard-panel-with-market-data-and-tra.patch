+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <meta name="theme-color" content="#06b6d4">
+  <link rel="manifest" href="/manifest.json">
+  <link rel="stylesheet" href="/css/site.css">
+  <title>Trading — Lantern OS</title>
+  <style>
+    :root {
+      --bg: #0b0d14;
+      --surface: #13161f;
+      --surface2: #1a1d2a;
+      --border: #252840;
+      --text: #e8eaf6;
+      --muted: #7880a4;
+      --accent: #7c6af7;
+      --green: #4caf82;
+      --gold: #e2c97e;
+      --danger: #e05555;
+      --warning: #f0a040;
+    }
+    html, body {
+      min-height: 100%;
+      background: var(--bg);
+      color: var(--text);
+      font-family: "Segoe UI", system-ui, sans-serif;
+      font-size: 15px;
+      line-height: 1.6;
+      margin: 0;
